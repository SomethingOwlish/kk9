{{!-- КК9 | Карточка навыка v2.0 --}}
<form class="kk9-sheet item-sheet skill-sheet" autocomplete="off">

  {{!-- ═══ ШАПКА ═══ --}}
  <header class="sk-header">
    <img class="sk-avatar" src="{{item.img}}" data-edit="img" title="{{item.name}}" />
    <div class="sk-header-right">
      <div class="sk-name-row">
        <input class="sk-name-input" type="text" name="name"
               value="{{item.name}}" placeholder="Название навыка" />
        {{#if system.isBase}}
        <span class="sk-base-badge">базовый</span>
        {{/if}}
      </div>
      <div class="sk-attr-row">
        <span class="sk-attr-label">Атрибут</span>
        <span class="sk-attr-value">
          {{#if (eq system.linkedAttribute "agility")}}Ловкость
          {{else if (eq system.linkedAttribute "smarts")}}Смекалка
          {{else if (eq system.linkedAttribute "spirit")}}Дух
          {{else if (eq system.linkedAttribute "strength")}}Сила
          {{else if (eq system.linkedAttribute "magic")}}Магия
          {{else}}—{{/if}}
        </span>
      </div>
    </div>
  </header>

  {{!-- ═══ ТЕЛО ═══ --}}
  <div class="sk-body">

    {{!-- Параметры --}}
    <div class="sk-params-grid">

      <div class="sk-param-block">
        <span class="sk-param-label">Связанный атрибут</span>
        <select name="system.linkedAttribute" class="kk9-select">
          <option value="agility"  {{#if (eq system.linkedAttribute "agility")}}selected{{/if}}>Ловкость</option>
          <option value="smarts"   {{#if (eq system.linkedAttribute "smarts")}}selected{{/if}}>Смекалка</option>
          <option value="spirit"   {{#if (eq system.linkedAttribute "spirit")}}selected{{/if}}>Дух</option>
          <option value="strength" {{#if (eq system.linkedAttribute "strength")}}selected{{/if}}>Сила</option>
          <option value="magic"    {{#if (eq system.linkedAttribute "magic")}}selected{{/if}}>Магия</option>
        </select>
      </div>

      <div class="sk-param-block">
        <span class="sk-param-label">Кубик</span>
        <select name="system.die" class="kk9-select">
          <option value="4"  {{#if (eq system.die 4)}}selected{{/if}}>d4</option>
          <option value="6"  {{#if (eq system.die 6)}}selected{{/if}}>d6</option>
          <option value="8"  {{#if (eq system.die 8)}}selected{{/if}}>d8</option>
          <option value="10" {{#if (eq system.die 10)}}selected{{/if}}>d10</option>
          <option value="12" {{#if (eq system.die 12)}}selected{{/if}}>d12</option>
          <option value="20" {{#if (eq system.die 20)}}selected{{/if}}>d20</option>
        </select>
      </div>

      <div class="sk-param-block sk-param-block--sm">
        <span class="sk-param-label">Модификатор</span>
        <input type="number" name="system.modifier"
               value="{{system.modifier}}" class="kk9-input sk-mod-input" />
      </div>

    </div>

    {{!-- Итоговая формула --}}
    <div class="sk-formula-row">
      <span class="sk-formula-label">Бросок</span>
      <span class="sk-formula-val">
        1d{{system.die}}
        {{#if system.modifier}}
          {{#if (gt system.modifier 0)}}+{{system.modifier}}{{else}}{{system.modifier}}{{/if}}
        {{/if}}
      </span>
    </div>

    {{!-- Описание --}}
    <div class="sk-desc-block">
      <span class="sk-param-label">Описание</span>
      <textarea name="system.description" class="kk9-textarea sk-desc-ta"
                placeholder="Описание навыка...">{{system.description}}</textarea>
    </div>

  </div>

</form>

<style>
/* ── Переключаем на вертикальный layout ── */
.skill-sheet {
  flex-direction: column !important;
  overflow-y: auto;
}

/* ── Шапка ── */
.skill-sheet .sk-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12px;
  padding: 10px 14px;
  background: var(--bg2);
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
}

.skill-sheet .sk-avatar {
  width: 48px; height: 48px;
  border-radius: 50%; object-fit: cover;
  cursor: pointer; flex-shrink: 0;
  border: 2px solid var(--border2);
}

.skill-sheet .sk-header-right {
  flex: 1; min-width: 0;
  display: flex; flex-direction: column; gap: 4px;
}

.skill-sheet .sk-name-row {
  display: flex; align-items: center; gap: 8px;
}

.skill-sheet .sk-name-input {
  flex: 1;
  font-family: 'Caveat', cursive;
  font-size: 1.4em; font-weight: 700;
  background: transparent; border: none;
  border-bottom: 2px solid var(--border2);
  color: var(--text-head);
  padding: 0 0 1px; outline: none;
  transition: border-color 0.2s;
  min-width: 0;
}
.skill-sheet .sk-name-input:focus {
  border-bottom-color: var(--gold);
}

.skill-sheet .sk-base-badge {
  flex-shrink: 0;
  font-size: 0.66em; font-weight: 500;
  text-transform: uppercase; letter-spacing: 0.07em;
  padding: 2px 8px; border-radius: 10px;
  background: rgba(196,164,74,0.12);
  color: var(--gold-dim);
  border: 1px solid rgba(196,164,74,0.25);
}

.skill-sheet .sk-attr-row {
  display: flex; align-items: center; gap: 6px;
}
.skill-sheet .sk-attr-label {
  font-size: 0.65em; text-transform: uppercase;
  letter-spacing: 0.07em; color: var(--text-dim);
}
.skill-sheet .sk-attr-value {
  font-size: 0.78em; color: var(--text);
}

/* ── Тело ── */
.skill-sheet .sk-body {
  flex: 1;
  padding: 12px 14px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  overflow-y: auto;
}

/* Параметры — три колонки */
.skill-sheet .sk-params-grid {
  display: grid;
  grid-template-columns: 1fr 1fr auto;
  gap: 10px;
  align-items: end;
}

.skill-sheet .sk-param-block {
  display: flex; flex-direction: column; gap: 3px;
}
.skill-sheet .sk-param-block--sm { min-width: 80px; }

.skill-sheet .sk-param-label {
  font-size: 0.65em;
  text-transform: uppercase; letter-spacing: 0.07em;
  color: var(--text-dim);
}

.skill-sheet .sk-mod-input {
  width: 70px !important;
  text-align: center;
}

/* Формула броска */
.skill-sheet .sk-formula-row {
  display: flex; align-items: center; gap: 8px;
  padding: 6px 10px;
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: 4px;
}
.skill-sheet .sk-formula-label {
  font-size: 0.68em; text-transform: uppercase;
  letter-spacing: 0.07em; color: var(--text-dim);
}
.skill-sheet .sk-formula-val {
  font-family: 'Caveat', cursive;
  font-size: 1.1em; font-weight: 700;
  color: var(--gold);
}

/* Описание */
.skill-sheet .sk-desc-block {
  display: flex; flex-direction: column; gap: 4px;
}
.skill-sheet .sk-desc-ta {
  min-height: 80px;
}
</style>
