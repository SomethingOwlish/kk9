{{!-- КК9 | Карточка артефакта v2.0 --}}
<form class="kk9-sheet item-sheet artifact-sheet" autocomplete="off">
  <header class="sheet-header" style="display:flex;gap:10px;align-items:center">
    <img class="profile-img" src="{{item.img}}" data-edit="img" title="{{item.name}}" />
    <div class="header-fields" style="flex:1;min-width:0">
      <input class="name-input" type="text" name="name" value="{{item.name}}" />
      <select name="system.rarity" class="rarity-select rarity-{{system.rarity}}">
        {{#each rarityOptions}}
        <option value="{{value}}" {{#if (eq value ../system.rarity)}}selected{{/if}}>{{label}}</option>
        {{/each}}
      </select>
    </div>
    {{!-- Бейдж состояния --}}
    {{#if system.destroyed}}
      <span class="kk9-condition-badge condition-broken">уничтожен</span>
    {{else if system.active}}
      <span class="kk9-condition-badge condition-perfect">активен</span>
    {{else}}
      <span class="kk9-condition-badge condition-good">неактивен</span>
    {{/if}}
  </header>

  <nav class="sheet-tabs" data-group="primary">
    <a class="item" data-tab="description">Описание</a>
    <a class="item" data-tab="details">Параметры</a>
  </nav>

  <div class="sheet-body">

    {{!-- ОПИСАНИЕ --}}
    <div class="tab" data-group="primary" data-tab="description">
      {{editor system.description target="system.description" button=true editable=editable}}
    </div>

    {{!-- ПАРАМЕТРЫ --}}
    <div class="tab" data-group="primary" data-tab="details">

      {{!-- Состояние артефакта --}}
      <div class="kk9-condition-row" style="margin-bottom:12px">
        <span class="kk9-condition-label">Состояние</span>
        <div class="kk9-condition-pips">
          <label class="kk9-cond-pip {{#if system.destroyed}}cond-active cond-broken{{/if}}" title="Уничтожен — не работает">
            <input type="checkbox" name="system.destroyed" {{#if system.destroyed}}checked{{/if}} style="display:none">
            <span>✕</span>
          </label>
          <label class="kk9-cond-pip {{#unless system.destroyed}}{{#unless system.active}}cond-active cond-good{{/unless}}{{/unless}}" title="Экипирован, но не активен">
            <span>◆</span>
          </label>
          <label class="kk9-cond-pip {{#if system.active}}{{#unless system.destroyed}}cond-active cond-perfect{{/unless}}{{/if}}" title="Активен — даёт бонусы">
            <input type="checkbox" name="system.active" {{#if system.active}}checked{{/if}} style="display:none">
            <span>★</span>
          </label>
        </div>
        <span style="font-size:0.7em;color:var(--text-dim);margin-left:8px">
          {{#if system.destroyed}}уничтожен{{else if system.active}}активен — бонусы работают{{else}}неактивен{{/if}}
        </span>
      </div>

      {{!-- Экипирован --}}
      <div class="stat-row" style="margin-bottom:8px">
        <label style="font-size:0.8em;color:var(--text-dim)">Экипирован</label>
        <input type="checkbox" name="system.equipped" {{#if system.equipped}}checked{{/if}} />
      </div>

      {{!-- Тип и класс --}}
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:10px">
        <div><label style="font-size:0.75em;color:var(--text-dim);display:block">Тип</label>
          <select name="system.artifact_type" class="kk9-select">
            <option value="attack"      {{#if (eq system.artifact_type "attack")}}selected{{/if}}>Атака</option>
            <option value="defense"     {{#if (eq system.artifact_type "defense")}}selected{{/if}}>Защита</option>
            <option value="binding"     {{#if (eq system.artifact_type "binding")}}selected{{/if}}>Связывание</option>
            <option value="spatial"     {{#if (eq system.artifact_type "spatial")}}selected{{/if}}>Пространственный</option>
            <option value="utility"     {{#if (eq system.artifact_type "utility")}}selected{{/if}}>Утилита</option>
            <option value="buff"        {{#if (eq system.artifact_type "buff")}}selected{{/if}}>Усиление</option>
            <option value="transforming"{{#if (eq system.artifact_type "transforming")}}selected{{/if}}>Трансформация</option>
            <option value="prophetic"   {{#if (eq system.artifact_type "prophetic")}}selected{{/if}}>Пророческий</option>
            <option value="wand"        {{#if (eq system.artifact_type "wand")}}selected{{/if}}>Палочка</option>
          </select></div>
        <div><label style="font-size:0.75em;color:var(--text-dim);display:block">Класс</label>
          <select name="system.artifact_class" class="kk9-select">
            <option value="simple"  {{#if (eq system.artifact_class "simple")}}selected{{/if}}>Простой</option>
            <option value="complex" {{#if (eq system.artifact_class "complex")}}selected{{/if}}>Сложный</option>
          </select></div>
        <div><label style="font-size:0.75em;color:var(--text-dim);display:block">Размер</label>
          <select name="system.size" class="kk9-select">
            <option value="finger"    {{#if (eq system.size "finger")}}selected{{/if}}>Пальцевый</option>
            <option value="pocket"    {{#if (eq system.size "pocket")}}selected{{/if}}>Карманный</option>
            <option value="small"     {{#if (eq system.size "small")}}selected{{/if}}>Малый</option>
            <option value="medium"    {{#if (eq system.size "medium")}}selected{{/if}}>Средний</option>
            <option value="large"     {{#if (eq system.size "large")}}selected{{/if}}>Большой</option>
            <option value="huge"      {{#if (eq system.size "huge")}}selected{{/if}}>Огромный</option>
            <option value="immovable" {{#if (eq system.size "immovable")}}selected{{/if}}>Неподвижный</option>
          </select></div>
        <div><label style="font-size:0.75em;color:var(--text-dim);display:block">Возраст (лет)</label>
          <input type="number" name="system.artifact_age" value="{{system.artifact_age}}" class="kk9-input" /></div>
      </div>

      {{!-- Создатель и условие активации --}}
      <div style="display:flex;flex-direction:column;gap:6px;margin-bottom:10px">
        <div><label style="font-size:0.75em;color:var(--text-dim);display:block">Создатель</label>
          <input type="text" name="system.creator" value="{{system.creator}}" class="kk9-input" placeholder="Имя создателя" /></div>
        <div><label style="font-size:0.75em;color:var(--text-dim);display:block">Условие активации</label>
          <input type="text" name="system.activation_condition" value="{{system.activation_condition}}" class="kk9-input" placeholder="Как активировать" /></div>
      </div>

      {{!-- Бонусы к атрибутам --}}
      <div class="section-title" style="margin-bottom:6px">Бонусы к атрибутам</div>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:6px;margin-bottom:10px">
        {{#each system.bonuses as |val key|}}
        <div>
          <label style="font-size:0.68em;color:var(--text-dim);display:block;text-transform:uppercase;letter-spacing:0.05em">{{key}}</label>
          <input type="number" name="system.bonuses.{{key}}" value="{{val}}" class="kk9-input" style="text-align:center" />
        </div>
        {{/each}}
      </div>

      {{!-- Бонусы к навыкам — drag-drop --}}
      <div class="section-title" style="margin-bottom:6px">Бонусы к навыкам</div>
      <div class="artifact-skill-bonuses-drop" style="min-height:32px;border:1px dashed var(--border2);border-radius:3px;padding:4px 8px;margin-bottom:6px">
        {{#each system.skill_bonuses}}
        <div style="display:flex;align-items:center;gap:6px;padding:2px 0">
          <span style="flex:1;font-size:0.84em;color:var(--text)">{{item_name}}</span>
          <input type="number" name="system.skill_bonuses.{{@index}}.bonus" value="{{bonus}}" class="kk9-input" style="width:50px;text-align:center" />
          <button type="button" class="btn-delete-xs artifact-skill-bonus-del" data-index="{{@index}}">✕</button>
        </div>
        {{else}}
        <span style="font-size:0.72em;color:var(--text-dim);font-style:italic">Перетащи навык или способность</span>
        {{/each}}
      </div>

      {{!-- Атакующие параметры --}}
      {{#if (eq system.artifact_type "attack")}}
      <div class="section-title" style="margin-bottom:6px">Атака</div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
        <div><label style="font-size:0.75em;color:var(--text-dim);display:block">Уровень урона</label>
          <select name="system.damage_level" class="kk9-select">
            <option value="light"  {{#if (eq system.damage_level "light")}}selected{{/if}}>Лёгкий</option>
            <option value="heavy"  {{#if (eq system.damage_level "heavy")}}selected{{/if}}>Тяжёлый</option>
            <option value="lethal" {{#if (eq system.damage_level "lethal")}}selected{{/if}}>Летальный</option>
          </select></div>
        <div><label style="font-size:0.75em;color:var(--text-dim);display:block">Тип урона</label>
          <select name="system.damage_type" class="kk9-select">
            <option value="physical" {{#if (eq system.damage_type "physical")}}selected{{/if}}>Физический</option>
            <option value="mental"   {{#if (eq system.damage_type "mental")}}selected{{/if}}>Ментальный</option>
          </select></div>
      </div>
      {{/if}}

      {{!-- Восстановление энергии --}}
      <div style="margin-top:12px;display:flex;align-items:center;gap:8px">
        <label style="font-size:0.75em;color:var(--text-dim);min-width:150px">⚡ Восстановление энергии</label>
        <input type="number" name="system.energy_restore" value="{{system.energy_restore}}"
               class="kk9-input" min="0" style="width:60px;text-align:center" />
        {{#if (gt system.energy_restore 0)}}
        <button type="button" class="art-use-energy-restore kk9-btn-energy"
                title="Использовать артефакт — восстановить энергию">
          ✦ Восстановить (+{{system.energy_restore}})
        </button>
        {{/if}}
      </div>

    </div>
  </div>
</form>
