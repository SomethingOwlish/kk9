{{!-- КК9 | Уникальная абилка --}}
<form class="kk9-sheet item-sheet ability-sheet" autocomplete="off">
  <header class="sheet-header">
    <img class="profile-img" src="{{item.img}}" data-edit="img" title="{{item.name}}" />
    <div class="header-fields">
      <input class="name-input" type="text" name="name" value="{{item.name}}" />
      <select name="system.type" class="type-select">
        <option value="passive" {{#if (eq system.type "passive")}}selected{{/if}}>Пассивная</option>
        <option value="active"  {{#if (eq system.type "active")}}selected{{/if}}>Активная</option>
      </select>
    </div>
  </header>
  <div class="sheet-body">
    {{#if (eq system.type "active")}}
    <div class="form-group">
      <label>Условие активации:</label>
      <input type="text" name="system.activation" value="{{system.activation}}" />
    </div>
    {{/if}}
    <div class="form-group">
      <label>Описание:</label>
      {{editor system.description target="system.description" button=true editable=editable}}
    </div>
  </div>
</form>
