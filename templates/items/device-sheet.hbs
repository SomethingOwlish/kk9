<form class="kk9-sheet item-sheet" autocomplete="off">
  <header style="display:flex;gap:10px;align-items:center;padding:10px;background:var(--bg2);border-bottom:1px solid var(--border)">
    <img src="{{item.img}}" data-edit="img" style="width:48px;height:48px;border-radius:4px;cursor:pointer;object-fit:cover" />
    <div style="flex:1;min-width:0">
      <input type="text" name="name" value="{{item.name}}"
             style="font-family:'Caveat',cursive;font-size:1.3em;background:transparent;border:none;border-bottom:1px solid var(--border2);color:var(--text-head);width:100%" />
    </div>
    <select name="system.condition" class="kk9-select" style="width:110px;font-size:0.8em">
      <option value="perfect" {{#if (eq system.condition "perfect")}}selected{{/if}}>★ Идеальное</option>
      <option value="good"    {{#if (eq system.condition "good")}}selected{{/if}}>◆ Нормальное</option>
      <option value="worn"    {{#if (eq system.condition "worn")}}selected{{/if}}>▼ Плохое</option>
      <option value="broken"  {{#if (eq system.condition "broken")}}selected{{/if}}>✕ Сломано</option>
    </select>
  </header>

  <div style="padding:12px;display:flex;flex-direction:column;gap:10px">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
      <div><label style="font-size:0.75em;color:var(--text-dim);display:block">Тип устройства</label>
        <select name="system.device_type" class="kk9-select">
          <option value="gadget"   {{#if (eq system.device_type "gadget")}}selected{{/if}}>Гаджет</option>
          <option value="weapon"   {{#if (eq system.device_type "weapon")}}selected{{/if}}>Оружие</option>
          <option value="drone"    {{#if (eq system.device_type "drone")}}selected{{/if}}>Дрон</option>
          <option value="computer" {{#if (eq system.device_type "computer")}}selected{{/if}}>Компьютер</option>
          <option value="medical"  {{#if (eq system.device_type "medical")}}selected{{/if}}>Медицинское</option>
          <option value="other"    {{#if (eq system.device_type "other")}}selected{{/if}}>Прочее</option>
        </select></div>
      <div><label style="font-size:0.75em;color:var(--text-dim);display:block">Заряды (−1 = ∞)</label>
        <input type="number" name="system.charges" value="{{system.charges}}" class="kk9-input" /></div>
    </div>

    {{!-- Weapon-type fields --}}
    {{#if (eq system.device_type "weapon")}}
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
      <div><label style="font-size:0.75em;color:var(--text-dim);display:block">Уровень урона</label>
        <select name="system.damage_level" class="kk9-select">
          <option value="light"  {{#if (eq system.damage_level "light")}}selected{{/if}}>Лёгкий</option>
          <option value="heavy"  {{#if (eq system.damage_level "heavy")}}selected{{/if}}>Тяжёлый</option>
          <option value="lethal" {{#if (eq system.damage_level "lethal")}}selected{{/if}}>Летальный</option>
        </select></div>
      <div><label style="font-size:0.75em;color:var(--text-dim);display:block">Тип урона</label>
        <select name="system.damage_type" class="kk9-select">
          <option value="physical" {{#if (eq system.damage_type "physical")}}selected{{/if}}>Физический</option>
          <option value="mental"   {{#if (eq system.damage_type "mental")}}selected{{/if}}>Ментальный</option>
        </select></div>
      <div><label style="font-size:0.75em;color:var(--text-dim);display:block">Дальность (м)</label>
        <input type="number" name="system.range" value="{{system.range}}" class="kk9-input" /></div>
    </div>
    {{!-- Навык атаки + модификатор --}}
    <div>
      <label style="font-size:0.75em;color:var(--text-dim);display:block;margin-bottom:4px">Навык атаки</label>
      <div style="display:flex;align-items:flex-end;gap:6px">
        <div style="flex:1;display:flex;align-items:center;gap:8px;padding:6px 8px;background:var(--bg2);border:1px solid var(--border);border-radius:3px;min-height:32px"
             class="device-attack-skill-drop">
          {{#if system.attack_skill_name}}
            <span style="flex:1;font-size:0.84em">{{system.attack_skill_name}}</span>
            <button type="button" class="btn-delete-xs device-clear-attack-skill">✕</button>
            <input type="hidden" name="system.attack_skill_uuid" value="{{system.attack_skill_uuid}}" />
            <input type="hidden" name="system.attack_skill_name" value="{{system.attack_skill_name}}" />
          {{else}}
            <span style="font-size:0.72em;color:var(--text-dim);font-style:italic">Перетащи навык или способность</span>
            <input type="hidden" name="system.attack_skill_uuid" value="" />
            <input type="hidden" name="system.attack_skill_name" value="" />
          {{/if}}
        </div>
        <div style="display:flex;flex-direction:column;align-items:center;gap:2px;flex-shrink:0;min-height:44px">
          <label style="font-size:0.68em;color:var(--text-dim);white-space:nowrap;line-height:1">мод.</label>
          <input type="number" name="system.attack_modifier" value="{{system.attack_modifier}}"
                 class="kk9-input" style="width:48px;text-align:center;flex:1;margin-top:2px"
                 title="Применяется если у персонажа нет навыка" />
        </div>
      </div>
    </div>
    {{!-- Статус при попадании --}}
    <div>
      <label style="font-size:0.75em;color:var(--text-dim);display:block;margin-bottom:4px">Статус при попадании</label>
      <div style="display:flex;align-items:center;gap:8px;padding:6px 8px;background:var(--bg2);border:1px solid var(--border);border-radius:3px;min-height:32px"
           class="device-status-drop">
        {{#if system.status_name}}
          <span style="flex:1;font-size:0.84em">{{system.status_name}}</span>
          <button type="button" class="btn-delete-xs device-clear-status">✕</button>
          <input type="hidden" name="system.status_uuid" value="{{system.status_uuid}}" />
          <input type="hidden" name="system.status_name" value="{{system.status_name}}" />
        {{else}}
          <span style="font-size:0.72em;color:var(--text-dim);font-style:italic">Перетащи статус-эффект</span>
          <input type="hidden" name="system.status_uuid" value="" />
          <input type="hidden" name="system.status_name" value="" />
        {{/if}}
      </div>
    </div>
    {{!-- Кнопка броска — всегда видна --}}
    <button type="button" class="device-attack-roll" style="padding:4px 12px;background:var(--gold);color:#000;border:none;border-radius:3px;cursor:pointer;font-size:0.85em;width:100%">
      ⚔ Бросок атаки
    </button>
    {{!-- % эффекта состояния — только для perfect/worn --}}
    {{#if (or (eq system.condition "perfect") (eq system.condition "worn"))}}
    <div style="display:flex;align-items:center;gap:8px">
      <label style="font-size:0.75em;color:var(--text-dim);white-space:nowrap">% эффекта состояния</label>
      <input type="number" name="system.condition_chance" value="{{system.condition_chance}}"
             class="kk9-input" min="0" max="100" style="width:60px;text-align:center"
             title="Идеальный: шанс +1 урон. Плохой: шанс нет урона." />
    </div>
    {{/if}}
    {{/if}}

    {{!-- Бонус к навыку — скрыт для типа weapon (там есть навык атаки) --}}
    {{#unless (eq system.device_type "weapon")}}
    <div>
      <label style="font-size:0.75em;color:var(--text-dim);display:block;margin-bottom:4px">Бонус к навыку</label>
      <div style="display:flex;align-items:center;gap:8px;padding:6px 8px;background:var(--bg2);border:1px solid var(--border);border-radius:3px;min-height:32px"
           class="device-skill-drop">
        {{#if system.bonus_skill_name}}
          <span style="flex:1;font-size:0.84em">{{system.bonus_skill_name}}</span>
          <input type="number" name="system.bonus_value" value="{{system.bonus_value}}" class="kk9-input" style="width:50px;text-align:center" />
          <button type="button" class="btn-delete-xs device-clear-skill">✕</button>
          <input type="hidden" name="system.bonus_skill_uuid" value="{{system.bonus_skill_uuid}}" />
          <input type="hidden" name="system.bonus_skill_name" value="{{system.bonus_skill_name}}" />
        {{else}}
          <span style="font-size:0.72em;color:var(--text-dim);font-style:italic">Перетащи навык или способность</span>
          <input type="hidden" name="system.bonus_skill_uuid" value="" />
          <input type="hidden" name="system.bonus_skill_name" value="" />
        {{/if}}
      </div>
    </div>
    {{/unless}}

    <div><label style="font-size:0.75em;color:var(--text-dim);display:block">Создатель</label>
      <input type="text" name="system.creator" value="{{system.creator}}" class="kk9-input" placeholder="Кто создал" /></div>

    <div style="display:flex;gap:16px;align-items:center">
      <label style="font-size:0.75em;color:var(--text-dim);display:flex;align-items:center;gap:4px">
        <input type="checkbox" name="system.works_upper" {{#if system.works_upper}}checked{{/if}} />
        Верхний мир
      </label>
      <label style="font-size:0.75em;color:var(--text-dim);display:flex;align-items:center;gap:4px">
        <input type="checkbox" name="system.works_lower" {{#if system.works_lower}}checked{{/if}} />
        Нижний мир
      </label>
      <div style="margin-left:auto;display:flex;align-items:center;gap:6px">
        <label style="font-size:0.75em;color:var(--text-dim)">Экипировка</label>
        <div style="display:flex;gap:4px">
          <button type="button" class="kk9-equip-toggle"
            style="padding:3px 8px;font-size:0.78em;border-radius:3px;cursor:pointer;
              background:{{#if (eq system.equipped 'home')}}var(--gold){{else}}var(--bg2){{/if}};
              color:{{#if (eq system.equipped 'home')}}#000{{else}}var(--text-dim){{/if}};
              border:1px solid {{#if (eq system.equipped 'home')}}var(--gold){{else}}var(--border){{/if}};"
            data-value="home">Дома</button>
          <button type="button" class="kk9-equip-toggle"
            style="padding:3px 8px;font-size:0.78em;border-radius:3px;cursor:pointer;
              background:{{#if (eq system.equipped 'carried')}}var(--gold){{else}}var(--bg2){{/if}};
              color:{{#if (eq system.equipped 'carried')}}#000{{else}}var(--text-dim){{/if}};
              border:1px solid {{#if (eq system.equipped 'carried')}}var(--gold){{else}}var(--border){{/if}};"
            data-value="carried">С собой</button>
          <button type="button" class="kk9-equip-toggle"
            style="padding:3px 8px;font-size:0.78em;border-radius:3px;cursor:pointer;
              background:{{#if (eq system.equipped 'equipped')}}var(--gold){{else}}var(--bg2){{/if}};
              color:{{#if (eq system.equipped 'equipped')}}#000{{else}}var(--text-dim){{/if}};
              border:1px solid {{#if (eq system.equipped 'equipped')}}var(--gold){{else}}var(--border){{/if}};"
            data-value="equipped">Экипирован</button>
          <input type="hidden" name="system.equipped" value="{{system.equipped}}" class="kk9-equip-hidden" />
        </div>
      </div>
    </div>

    <div>
      <label style="font-size:0.75em;color:var(--text-dim);display:block;margin-bottom:4px">Описание</label>
      <textarea name="system.description" class="kk9-textarea" style="min-height:120px;width:100%;resize:vertical" placeholder="Описание...">{{system.description}}</textarea>
    </div>
  </div>
</form>
