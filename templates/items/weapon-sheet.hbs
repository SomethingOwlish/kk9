<form class="kk9-sheet item-sheet" autocomplete="off">
  <header style="display:flex;gap:10px;align-items:center;padding:10px;background:var(--bg2);border-bottom:1px solid var(--border)">
    <img src="{{item.img}}" data-edit="img" style="width:48px;height:48px;border-radius:4px;cursor:pointer;object-fit:cover" />
    <div style="flex:1">
      <input type="text" name="name" value="{{item.name}}"
             style="font-family:'Caveat',cursive;font-size:1.3em;background:transparent;border:none;border-bottom:1px solid var(--border2);color:var(--text-head);width:100%" />
    </div>
  </header>
  <div style="padding:12px;display:flex;flex-direction:column;gap:8px">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
      <div><label style="font-size:0.75em;color:var(--text-dim);display:block">Урон</label>
        <input type="text" name="system.damage" value="{{system.damage}}" placeholder="Str+d6" class="kk9-input" /></div>
      <div><label style="font-size:0.75em;color:var(--text-dim);display:block">Дальность</label>
        <input type="text" name="system.range" value="{{system.range}}" placeholder="Ближний" class="kk9-input" /></div>
      <div><label style="font-size:0.75em;color:var(--text-dim);display:block">Бронепробивание</label>
        <input type="number" name="system.ap" value="{{system.ap}}" class="kk9-input" /></div>
      <div><label style="font-size:0.75em;color:var(--text-dim);display:block">Скорострельность</label>
        <input type="number" name="system.rof" value="{{system.rof}}" class="kk9-input" /></div>
    </div>
    <div style="display:flex;align-items:center;gap:8px">
      <label style="font-size:0.75em;color:var(--text-dim)">Экипировано</label>
      <input type="checkbox" name="system.equipped" {{#if system.equipped}}checked{{/if}} />
    </div>
    <button type="button" class="roll-damage btn-roll" style="align-self:flex-start">🎲 Бросить урон</button>
    <div>
      <label style="font-size:0.75em;color:var(--text-dim);display:block;margin-bottom:4px">Описание</label>
      {{editor system.description target="system.description" button=true editable=editable}}
    </div>
  </div>
</form>
