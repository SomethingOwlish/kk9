<form class="kk9-sheet item-sheet" autocomplete="off">
  <header style="display:flex;gap:10px;align-items:center;padding:10px;background:var(--bg2);border-bottom:1px solid var(--border)">
    <img src="{{item.img}}" data-edit="img" style="width:48px;height:48px;border-radius:4px;cursor:pointer;object-fit:cover" />
    <div style="flex:1;min-width:0">
      <input type="text" name="name" value="{{item.name}}"
             style="font-family:'Caveat',cursive;font-size:1.3em;background:transparent;border:none;border-bottom:1px solid var(--border2);color:var(--text-head);width:100%" />
    </div>
    <select name="system.condition" class="kk9-select" style="width:110px;font-size:0.8em">
      <option value="perfect" {{#if (eq system.condition "perfect")}}selected{{/if}}>★ Идеальное</option>
      <option value="good"    {{#if (eq system.condition "good")}}selected{{/if}}>◆ Нормальное</option>
      <option value="worn"    {{#if (eq system.condition "worn")}}selected{{/if}}>▼ Плохое</option>
      <option value="broken"  {{#if (eq system.condition "broken")}}selected{{/if}}>✕ Сломано</option>
    </select>
  </header>

  <div style="padding:12px;display:flex;flex-direction:column;gap:10px">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
      <div><label style="font-size:0.75em;color:var(--text-dim);display:block">Тип</label>
        <select name="system.gear_type" class="kk9-select">
          <option value="attack"  {{#if (eq system.gear_type "attack")}}selected{{/if}}>Атака</option>
          <option value="defense" {{#if (eq system.gear_type "defense")}}selected{{/if}}>Защита</option>
          <option value="utility" {{#if (eq system.gear_type "utility")}}selected{{/if}}>Утилита</option>
        </select></div>
      <div><label style="font-size:0.75em;color:var(--text-dim);display:block">Размер</label>
        <select name="system.size" class="kk9-select">
          <option value="finger"    {{#if (eq system.size "finger")}}selected{{/if}}>Пальцевый</option>
          <option value="pocket"    {{#if (eq system.size "pocket")}}selected{{/if}}>Карманный</option>
          <option value="small"     {{#if (eq system.size "small")}}selected{{/if}}>Малый</option>
          <option value="medium"    {{#if (eq system.size "medium")}}selected{{/if}}>Средний</option>
          <option value="large"     {{#if (eq system.size "large")}}selected{{/if}}>Большой</option>
          <option value="huge"      {{#if (eq system.size "huge")}}selected{{/if}}>Огромный</option>
          <option value="immovable" {{#if (eq system.size "immovable")}}selected{{/if}}>Неподвижный</option>
        </select></div>
      <div><label style="font-size:0.75em;color:var(--text-dim);display:block">Количество</label>
        <input type="number" name="system.quantity" value="{{system.quantity}}" min="0" class="kk9-input" /></div>
      <div style="display:flex;align-items:flex-end;gap:6px;padding-bottom:2px">
        <label style="font-size:0.75em;color:var(--text-dim)">Экипировано</label>
        <input type="checkbox" name="system.equipped" {{#if system.equipped}}checked{{/if}} />
      </div>
    </div>

    {{!-- Атакующие поля — только для типа attack --}}
    {{#if (eq system.gear_type "attack")}}
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
      <div><label style="font-size:0.75em;color:var(--text-dim);display:block">Уровень урона</label>
        <select name="system.damage_level" class="kk9-select">
          <option value="light"  {{#if (eq system.damage_level "light")}}selected{{/if}}>Лёгкий</option>
          <option value="heavy"  {{#if (eq system.damage_level "heavy")}}selected{{/if}}>Тяжёлый</option>
          <option value="lethal" {{#if (eq system.damage_level "lethal")}}selected{{/if}}>Летальный</option>
        </select></div>
      <div><label style="font-size:0.75em;color:var(--text-dim);display:block">Тип урона</label>
        <select name="system.damage_type" class="kk9-select">
          <option value="physical" {{#if (eq system.damage_type "physical")}}selected{{/if}}>Физический</option>
          <option value="mental"   {{#if (eq system.damage_type "mental")}}selected{{/if}}>Ментальный</option>
        </select></div>
    </div>
    <div>
      <label style="font-size:0.75em;color:var(--text-dim);display:block;margin-bottom:4px">Навык атаки</label>
      <div style="display:flex;align-items:center;gap:8px;padding:6px 8px;background:var(--bg2);border:1px solid var(--border);border-radius:3px;min-height:32px"
           class="gear-skill-drop">
        {{#if system.skill_name}}
          <span style="flex:1;font-size:0.84em">{{system.skill_name}}</span>
          <button type="button" class="btn-delete-xs gear-clear-skill">✕</button>
          <input type="hidden" name="system.skill_uuid" value="{{system.skill_uuid}}" />
          <input type="hidden" name="system.skill_name" value="{{system.skill_name}}" />
        {{else}}
          <span style="font-size:0.72em;color:var(--text-dim);font-style:italic">Перетащи навык</span>
          <input type="hidden" name="system.skill_uuid" value="" />
          <input type="hidden" name="system.skill_name" value="" />
        {{/if}}
      </div>
    </div>
    {{#if system.skill_name}}
    <button type="button" class="gear-attack-roll" style="padding:4px 12px;background:var(--gold);color:#000;border:none;border-radius:3px;cursor:pointer;font-size:0.85em;align-self:flex-start">
      ⚔ Бросок атаки
    </button>
    {{/if}}
    {{/if}}

    {{!-- Восстановление энергии — только для utility --}}
    {{#if (eq system.gear_type "utility")}}
    <div style="display:flex;align-items:center;gap:8px">
      <label style="font-size:0.75em;color:var(--text-dim);min-width:150px">Восстановление энергии</label>
      <input type="number" name="system.energy_restore" value="{{system.energy_restore}}"
             class="kk9-input" min="0" style="width:60px;text-align:center" />
      {{#if (gt system.energy_restore 0)}}
      <button type="button" class="gear-use-energy-restore" style="padding:4px 10px;background:rgba(196,164,74,0.2);color:var(--gold);border:1px solid rgba(196,164,74,0.4);border-radius:3px;cursor:pointer;font-size:0.8em">
        ✦ Использовать (+{{system.energy_restore}})
      </button>
      {{/if}}
    </div>
    {{/if}}

    <div>
      <label style="font-size:0.75em;color:var(--text-dim);display:block;margin-bottom:4px">Описание</label>
      <textarea name="system.description" class="kk9-textarea" style="min-height:120px;width:100%;resize:vertical" placeholder="Описание...">{{system.description}}</textarea>
    </div>
  </div>
</form>
