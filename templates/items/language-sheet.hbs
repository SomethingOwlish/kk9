{{!-- КК9 | Язык --}}
<form class="kk9-sheet item-sheet" autocomplete="off">
  <header class="sheet-header" style="padding:10px;background:var(--bg2,#232323);border-bottom:1px solid var(--border,#3a3a3a)">
    <img class="item-img" src="{{item.img}}" data-edit="img" style="width:48px;height:48px;border-radius:4px;cursor:pointer" />
    <div style="flex:1;padding-left:10px">
      <input type="text" name="name" value="{{item.name}}" style="font-size:1.2em;background:transparent;border:none;border-bottom:1px solid var(--border,#3a3a3a);color:var(--text-head,#d8d0c8);width:100%" />
    </div>
  </header>
  <div style="padding:12px">
    <div style="margin-bottom:8px">
      <label style="font-size:0.78em;color:var(--text-dim,#6a6560);text-transform:uppercase">Регион / происхождение</label>
      <input type="text" name="system.region" value="{{system.region}}" style="width:100%;margin-top:4px;background:var(--bg3,#2a2a2a);border:1px solid var(--border,#3a3a3a);border-radius:3px;color:var(--text,#b8b0a4);padding:4px 8px" />
    </div>
    <div>
      <label style="font-size:0.78em;color:var(--text-dim,#6a6560);text-transform:uppercase">Описание</label>
      <textarea name="system.description" rows="4" style="width:100%;margin-top:4px;background:var(--bg3,#2a2a2a);border:1px solid var(--border,#3a3a3a);border-radius:3px;color:var(--text,#b8b0a4);padding:6px 8px;font-family:inherit">{{system.description}}</textarea>
    </div>
  </div>
</form>
