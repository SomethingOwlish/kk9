<form class="kk9-sheet item-sheet" autocomplete="off">
  <header style="display:flex;gap:10px;align-items:center;padding:10px;background:var(--bg2);border-bottom:1px solid var(--border)">
    <img src="{{item.img}}" data-edit="img" style="width:48px;height:48px;border-radius:4px;cursor:pointer;object-fit:cover" />
    <div style="flex:1">
      <input type="text" name="name" value="{{item.name}}"
             style="font-family:'Caveat',cursive;font-size:1.3em;background:transparent;border:none;border-bottom:1px solid var(--border2);color:var(--text-head);width:100%" />
    </div>
  </header>
  <div style="padding:12px;display:flex;flex-direction:column;gap:8px">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
      <div><label style="font-size:0.75em;color:var(--text-dim);display:block">Тип организации</label>
        <select name="system.org_type" class="kk9-select">
          {{#each orgTypeOptions}}
          <option value="{{value}}" {{#if (eq value ../system.org_type)}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select></div>
      <div><label style="font-size:0.75em;color:var(--text-dim);display:block">Уровень доступа (1–5)</label>
        <input type="number" name="system.access_level" value="{{system.access_level}}" min="1" max="5" class="kk9-input" /></div>
    </div>
    <div><label style="font-size:0.75em;color:var(--text-dim);display:block">Представитель</label>
      <input type="text" name="system.representative" value="{{system.representative}}" class="kk9-input" placeholder="Имя куратора в организации" /></div>
    <div><label style="font-size:0.75em;color:var(--text-dim);display:block">Заметки</label>
      <textarea name="system.notes" rows="3" class="kk9-textarea">{{system.notes}}</textarea></div>
    <div>
      <label style="font-size:0.75em;color:var(--text-dim);display:block;margin-bottom:4px">Описание</label>
      {{editor system.description target="system.description" button=true editable=editable}}
    </div>
  </div>
</form>
