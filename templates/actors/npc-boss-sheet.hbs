{{!-- КК9 | Босс / Непобедимый НПС --}}
<form class="kk9-sheet npc-boss-sheet" autocomplete="off">
  <header class="sheet-header boss-header">
    <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" />
    <div class="header-fields">
      <input class="name-input" type="text" name="name" value="{{actor.name}}" />
      <span class="boss-badge">☠ Непобедимый</span>
    </div>
  </header>

  <div class="sheet-body">
    <div class="stat-row">
      <label>Уровень угрозы:</label>
      <input type="text" name="system.threat_level" value="{{system.threat_level}}" />
    </div>

    <div class="form-group">
      <label>Особые механики:</label>
      <textarea name="system.special_mechanics" rows="4">{{system.special_mechanics}}</textarea>
    </div>

    <div class="form-group">
      <label>Описание:</label>
      {{editor system.description target="system.description" button=true editable=editable}}
    </div>

    <div class="form-group">
      <label>Заметки мастера:</label>
      <textarea name="system.notes" rows="3">{{system.notes}}</textarea>
    </div>
  </div>
</form>
