{{!-- КК9 | Непобедимый НПС v2.8 --}}
<form class="kk9-sheet npc-boss-sheet" autocomplete="off">

  <div class="npc-sidebar">
    <div class="portrait-wrap">
      <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" />
      <div class="portrait-name-overlay">
        <input class="name-input" type="text" name="name" value="{{actor.name}}" placeholder="Имя" />
      </div>
    </div>

    <div class="npc-sidebar-body">
      <input type="text" name="system.role" value="{{system.role}}"
             placeholder="краткое описание..." class="npc-role-input" />

      <section class="relations-section">
        <div class="section-header-row">
          <h3 class="section-title">Связи</h3>
          <button type="button" class="add-relation btn-add-sm">+</button>
        </div>
        <p class="drop-hint" style="margin-bottom:6px;font-size:0.72em;color:var(--text-dim);font-style:italic">Перетащи карточку актора</p>
        <div class="relations-list" data-drop-zone="relations">
          {{#if system.relations.length}}
          {{#each system.relations as |rel|}}
          <div class="relation-row {{#if rel.love}}relation-love{{/if}}">
            <div class="relation-top-row">
              <input type="hidden" name="system.relations.{{@index}}.love" value="{{#if rel.love}}true{{else}}false{{/if}}" />
              <button type="button" class="love-toggle {{#if rel.love}}love-active{{/if}}" data-index="{{@index}}" title="Избранное">♥</button>
              <input type="text" name="system.relations.{{@index}}.name" value="{{rel.name}}" class="relation-name" placeholder="Имя..." />
              <select name="system.relations.{{@index}}.status" class="relation-status">
                <option value="ally"    {{#if (eq rel.status "ally")}}selected{{/if}}>Союзник</option>
                <option value="enemy"   {{#if (eq rel.status "enemy")}}selected{{/if}}>Враг</option>
                <option value="neutral" {{#if (eq rel.status "neutral")}}selected{{/if}}>Нейтрал</option>
                <option value="unknown" {{#if (eq rel.status "unknown")}}selected{{/if}}>?</option>
              </select>
              <button type="button" class="delete-relation btn-delete-xs" data-index="{{@index}}">✕</button>
            </div>
            <textarea name="system.relations.{{@index}}.notes" class="relation-notes" placeholder="Заметки...">{{rel.notes}}</textarea>
          </div>
          {{/each}}
          {{else}}
          <p class="empty-hint">Нет связей. Нажми «+» или перетащи.</p>
          {{/if}}
        </div>
      </section>
    </div>
  </div>

  <div class="npc-main">
    <nav class="sheet-tabs" data-group="primary">
      <a class="item" data-tab="main">Основное</a>
      {{#if canConflict}}<a class="item" data-tab="conflict">Конфликт</a>{{/if}}
    </nav>

    <div class="sheet-body">

      {{!-- ОСНОВНОЕ --}}
      <div class="tab" data-group="primary" data-tab="main">
        <div class="npc-fields-grid3">
          <div class="npc-field"><label>Возраст</label><input type="text" name="system.age" value="{{system.age}}" /></div>
          <div class="npc-field"><label>Раса</label><input type="text" name="system.race" value="{{system.race}}" /></div>
          <div class="npc-field"><label>Гендер</label><input type="text" name="system.gender" value="{{system.gender}}" /></div>
        </div>
        <div class="npc-fields-grid2">
          <div class="npc-field"><label>Мир происхождения</label><input type="text" name="system.world_origin" value="{{system.world_origin}}" placeholder="—" /></div>
          <div class="npc-field"><label>Страна происхождения</label><input type="text" name="system.country_origin" value="{{system.country_origin}}" placeholder="—" /></div>
          <div class="npc-field"><label>Мир проживания</label><input type="text" name="system.world_home" value="{{system.world_home}}" placeholder="—" /></div>
          <div class="npc-field"><label>Страна проживания</label><input type="text" name="system.country_home" value="{{system.country_home}}" placeholder="—" /></div>
        </div>
        <div class="npc-field" style="margin-bottom:8px"><label>Организации</label>
          <input type="text" name="system.organizations" value="{{system.organizations}}" placeholder="—" /></div>
        <div class="npc-field" style="margin-bottom:8px"><label>Цели</label>
          <textarea name="system.goals" rows="3" placeholder="чего хочет достичь...">{{system.goals}}</textarea></div>
        <div class="npc-field" style="margin-bottom:8px"><label>Мотивы</label>
          <textarea name="system.motives" rows="3" placeholder="что движет изнутри...">{{system.motives}}</textarea></div>
        <div class="npc-field" style="margin-bottom:8px"><label>Внешние особенности</label>
          <textarea name="system.appearance" rows="2" placeholder="внешность, особые приметы...">{{system.appearance}}</textarea></div>
        {{!-- Языки --}}
        <div class="bio-languages-block npc-languages-drop" data-drop-zone="languages" style="margin-bottom:10px">
          <div class="section-header-row">
            <div class="section-title" style="margin:0">Языки</div>
            <span class="drop-hint-sm">Перетащи из Items</span>
          </div>
          <div class="languages-list">
            {{#each system.languages as |lang|}}
            <div class="language-tag">
              <span>{{lang.name}}</span>
              <button type="button" class="btn-delete-language btn-delete-xs" data-index="{{@index}}">✕</button>
            </div>
            {{else}}
            <p class="empty-hint">Нет языков</p>
            {{/each}}
          </div>
        </div>
        <div class="section-title">Биография</div>
        <textarea name="system.biography" rows="6" class="npc-textarea-lg" placeholder="история персонажа...">{{system.biography}}</textarea>
        <div class="section-title" style="margin-top:10px">Заметки</div>
        <textarea name="system.notes" rows="4" class="npc-textarea-lg" placeholder="заметки мастера...">{{system.notes}}</textarea>
        {{!-- KK9 связь --}}
        <div class="kk9-linked-block" style="margin-top:10px;padding:8px;border:1px solid var(--border);border-radius:4px">
          <label class="kk9-linked-label" style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:0.82em;color:var(--text-dim);text-transform:uppercase;letter-spacing:0.08em">
            <input type="checkbox" name="system.kk9_linked" {{#if system.kk9_linked}}checked{{/if}} style="accent-color:var(--faculty-accent,var(--gold))" />
            Связан с KK9
          </label>
          {{#if isGM}}{{#if system.kk9_linked}}
          <div class="kk9-operative-block" style="margin-top:8px;padding:6px 8px;background:var(--bg2);border:1px dashed var(--border2);border-radius:3px" data-drop-zone="operative-faculty">
            <div class="section-title" style="margin-bottom:4px">Класс оперативника <span style="font-size:0.8em;color:var(--text-dim);font-weight:400">(только ГМ)</span></div>
            {{#if system.operative_class}}
            <div class="operative-faculty-row" style="display:flex;align-items:center;gap:8px">
              <span class="operative-faculty-name" style="color:var(--faculty-accent,var(--gold));font-size:0.9em;font-weight:500">{{system.operative_class}}</span>
              <button type="button" class="btn-delete-xs clear-operative-faculty" title="Убрать">✕</button>
            </div>
            {{else}}
            <p style="font-size:0.78em;color:var(--text-dim);font-style:italic;margin:0">Перетащи факультет сюда</p>
            {{/if}}
          </div>
          {{/if}}{{/if}}
        </div>
      </div>

      {{!-- КОНФЛИКТ --}}
      {{#if canConflict}}
      <div class="tab" data-group="primary" data-tab="conflict">

        <div class="section-title">Характеристики</div>
        <div class="npc-attributes-grid">
          {{#each system.attributes as |attr key|}}
          <div class="npc-attr-box rollable-npc-attr-boss" data-attribute="{{key}}" title="Бросить д6 + {{lookup ../attributeLabels key}}">
            <span class="npc-attr-label">{{lookup ../attributeLabels key}}</span>
            <span class="npc-attr-die npc-boss-die">д6+d{{attr.die}}</span>
            <select name="system.attributes.{{key}}.die" class="npc-die-select" onclick="event.stopPropagation()">
              <option value="4"   {{#if (eq attr.die 4)}}selected{{/if}}>d4</option>
              <option value="6"   {{#if (eq attr.die 6)}}selected{{/if}}>d6</option>
              <option value="8"   {{#if (eq attr.die 8)}}selected{{/if}}>d8</option>
              <option value="10"  {{#if (eq attr.die 10)}}selected{{/if}}>d10</option>
              <option value="12"  {{#if (eq attr.die 12)}}selected{{/if}}>d12</option>
              <option value="20"  {{#if (eq attr.die 20)}}selected{{/if}}>d20</option>
              <option value="100" {{#if (eq attr.die 100)}}selected{{/if}}>d100</option>
            </select>
          </div>
          {{/each}}
        </div>

        <div class="derived-bar" style="margin:10px 0">
          <div class="derived-btn roll-npc-initiative" title="Инициатива с диким кубиком">
            <span class="derived-lbl">Инициатива</span>
          </div>
          <div class="derived-btn roll-npc-toughness" title="Стойкость: 2 + Дух/2 = {{system.toughness}}. Бросок Духа + навык">
            <span class="derived-lbl">Стойкость</span>
          </div>
          <div class="derived-energy">
            <span class="derived-lbl">Энергия</span>
            <input type="number" name="system.energy.value" value="{{system.energy.value}}" class="energy-cur" min="0" {{#unless isGM}}readonly title="Только ГМ может изменять энергию вручную"{{/unless}} />
            <span class="energy-sep">/</span>
            <span class="energy-max">{{system.energy.max}}</span>
          </div>
        </div>

        <div class="derived-bar" style="margin:6px 0;align-items:center;gap:12px">
          <span class="derived-lbl" style="font-size:0.8em;color:var(--text-dim)">Дикий кубик</span>
          <select name="system.wild_die" class="die-select-sm" style="width:60px">
            <option value="4"  {{#if (eq system.wild_die 4)}}selected{{/if}}>d4</option>
            <option value="6"  {{#if (eq system.wild_die 6)}}selected{{/if}}>d6</option>
            <option value="8"  {{#if (eq system.wild_die 8)}}selected{{/if}}>d8</option>
            <option value="10" {{#if (eq system.wild_die 10)}}selected{{/if}}>d10</option>
            <option value="12" {{#if (eq system.wild_die 12)}}selected{{/if}}>d12</option>
          </select>
        </div>

        <div class="section-title">Особая механика</div>
        <textarea name="system.special_mechanics" rows="6" class="npc-textarea-lg"
                  placeholder="опишите уникальную механику: фазы, условия победы, особые правила...">{{system.special_mechanics}}</textarea>

        {{!-- Активные статусы --}}
        <div class="active-statuses-block actor-status-drop" style="margin-top:10px" title="Перетащи статус-итем сюда">
          <div class="active-statuses-header">
            <span class="active-statuses-title">Активные статусы</span>
          </div>
          {{#if system.active_statuses.length}}
          <div class="active-statuses-list">
            {{#each system.active_statuses as |st|}}
            <div class="active-status-row status-type-{{st.status_type}}">
              <span class="active-status-icon">{{#if (eq st.status_type "poison")}}☠{{else if (eq st.status_type "shock")}}⚡{{else if (eq st.status_type "magic")}}✦{{else if (eq st.status_type "bleed")}}🩸{{else if (eq st.status_type "acid")}}⚗{{/if}}</span>
              <span class="active-status-name">{{st.statusName}}</span>
              {{#if (ne st.uses -1)}}<span class="active-status-uses">{{st.uses}}×</span>{{/if}}
              <button type="button" class="actor-remove-status fac-del" data-index="{{@index}}">✕</button>
            </div>
            {{/each}}
          </div>
          {{else}}
          <div class="active-statuses-empty">Нет активных статусов · перетащи статус-итем</div>
          {{/if}}
        </div>

        <div class="section-title" style="margin-top:12px">Навыки и способности</div>
        <div class="npc-skill-list">
          {{#each npcAllItems}}
          <div class="skill-row" data-item-id="{{id}}">
            <span class="skill-name npc-rollable" data-item-id="{{id}}">{{name}}</span>
            <div class="skill-controls">
              <select class="die-select-sm npc-skill-die" data-item-id="{{id}}" onclick="event.stopPropagation()">
                <option value="4"  {{#if (eq system.die 4)}}selected{{/if}}>d4</option>
                <option value="6"  {{#if (eq system.die 6)}}selected{{/if}}>d6</option>
                <option value="8"  {{#if (eq system.die 8)}}selected{{/if}}>d8</option>
                <option value="10" {{#if (eq system.die 10)}}selected{{/if}}>d10</option>
                <option value="12" {{#if (eq system.die 12)}}selected{{/if}}>d12</option>
                <option value="20" {{#if (eq system.die 20)}}selected{{/if}}>d20</option>
              </select>
              <input type="number" class="mod-input-sm npc-skill-mod" data-item-id="{{id}}" value="{{system.modifier}}" placeholder="±0" />
              <button type="button" class="btn-delete-xs npc-item-del" data-item-id="{{id}}">✕</button>
            </div>
          </div>
          {{else}}
          <p class="drop-hint">Перетащи навыки или способности</p>
          {{/each}}
        </div>

        <div class="section-title" style="margin-top:12px">Снаряжение</div>
        <div class="npc-skill-list">
          {{#each npcGear}}
          <div class="skill-row" data-item-id="{{id}}">
            <span class="skill-name item-name-click" data-item-id="{{id}}">{{name}}</span>
            <div class="skill-controls">
              <span class="skill-attr-hint">{{npcItemTypeLabel type}}</span>
              {{!-- Кнопка атаки — только если экипировано --}}
              {{#if (and (eq type "weapon") (eq system.equipped "equipped"))}}
              <button type="button" class="item-attack-btn btn-ref-action" data-item-id="{{id}}" data-item-type="weapon"
                title="Бросок атаки"><i class="fa-solid fa-crosshairs"></i></button>
              {{/if}}
              {{#if (and (eq type "gear") (eq system.gear_type "attack") (eq system.equipped "equipped") (gt system.quantity 0))}}
              <button type="button" class="item-attack-btn btn-ref-action" data-item-id="{{id}}" data-item-type="gear"
                title="Бросок атаки"><i class="fa-solid fa-crosshairs"></i></button>
              {{/if}}
              {{#if (and (eq type "device") (eq system.device_type "weapon") (eq system.equipped "equipped") (or (eq system.charges -1) (gt system.charges 0)))}}
              <button type="button" class="item-attack-btn btn-ref-action" data-item-id="{{id}}" data-item-type="device"
                title="Бросок атаки"><i class="fa-solid fa-crosshairs"></i></button>
              {{/if}}
              {{#if (and (eq type "spell") (eq system.spell_type "attack"))}}
              <button type="button" class="item-attack-btn btn-ref-action" data-item-id="{{id}}" data-item-type="spell"
                title="Применить заклинание"><i class="fa-solid fa-wand-sparkles"></i></button>
              {{/if}}
              {{!-- Мета-инфо: количество / заряды / энергия --}}
              {{#if (and (eq type "gear") (eq system.gear_type "attack"))}}
              <span class="skill-attr-hint">×{{system.quantity}}</span>
              {{/if}}
              {{#if (and (eq type "device") (eq system.device_type "weapon"))}}
              <span class="skill-attr-hint">{{#if (eq system.charges -1)}}∞{{else}}{{system.charges}}⚡{{/if}}</span>
              {{/if}}
              {{#if (eq type "spell")}}
              <span class="skill-attr-hint">{{system.cost}} э.</span>
              {{/if}}
              {{!-- Переключатель экипировки (кроме спеллов) --}}
              {{#unless (eq type "spell")}}
              <button type="button" class="item-equip-btn btn-ref-icon" data-item-id="{{id}}" data-item-type="{{type}}"
                title="{{#if (eq system.equipped 'equipped')}}Экипировано{{else if (eq system.equipped 'carried')}}С собой{{else}}Дома{{/if}}">
                <i class="fa-solid {{#if (eq system.equipped 'equipped')}}fa-shield{{else if (eq system.equipped 'carried')}}fa-bag-shopping{{else}}fa-house{{/if}}"></i>
              </button>
              {{/unless}}
              <button type="button" class="btn-delete-xs npc-item-del" data-item-id="{{id}}">✕</button>
            </div>
          </div>
          {{else}}
          <p class="drop-hint">Перетащи предметы</p>
          {{/each}}
        </div>

        <div class="section-title" style="margin-top:12px">Связанные объекты</div>
        <div class="npc-skill-list">
          {{#each npcRefs}}
          <div class="skill-row" data-uuid="{{this.uuid}}" data-ref-type="{{this.refType}}"
               title="{{this.type}}">
            <span class="skill-name item-name-click">{{this.name}}</span>
            <div class="skill-controls">
              {{#if (eq this.refType "artifact")}}
                {{#if (eq this.system.artifact_type "attack")}}{{#if (eq this.system.equipped "equipped")}}{{#if this.system.active}}
                <button type="button" class="artifact-use-btn btn-ref-action" data-uuid="{{this.uuid}}" data-action="attack" title="Бросок атаки"><i class="fa-solid fa-crosshairs"></i></button>
                {{/if}}{{/if}}{{/if}}
                {{#if (eq this.system.artifact_type "utility")}}{{#if (eq this.system.equipped "equipped")}}{{#if this.system.active}}
                <button type="button" class="artifact-use-btn btn-ref-action" data-uuid="{{this.uuid}}" data-action="energy" title="Восстановить энергию"><i class="fa-solid fa-circle-plus"></i></button>
                {{/if}}{{/if}}{{/if}}
                <button type="button" class="artifact-toggle-btn btn-ref-icon" data-uuid="{{this.uuid}}" data-toggle="active" title="{{#if this.system.active}}Активен{{else}}Неактивен{{/if}}"><i class="fa-solid {{#if this.system.active}}fa-bolt{{else}}fa-bolt-slash{{/if}}"></i></button>
                <button type="button" class="artifact-toggle-btn btn-ref-icon" data-uuid="{{this.uuid}}" data-toggle="equipped" title="{{#if (eq this.system.equipped 'equipped')}}Экипирован{{else if (eq this.system.equipped 'carried')}}С собой{{else}}Дома{{/if}}"><i class="fa-solid {{#if (eq this.system.equipped 'equipped')}}fa-shield{{else if (eq this.system.equipped 'carried')}}fa-bag-shopping{{else}}fa-house{{/if}}"></i></button>
              {{/if}}
              <button type="button" class="btn-delete-xs npc-item-del" data-uuid="{{this.uuid}}" data-ref-type="{{this.refType}}">✕</button>
            </div>
          </div>
          {{else}}
          <p class="drop-hint">Перетащи артефакт, даймона, спутника или контакт</p>
          {{/each}}
        </div>

        <div class="section-title" style="margin-top:12px">Критический урон</div>
        <div style="display:flex;align-items:center;gap:12px;padding:8px 10px;background:var(--bg2);border:1px solid var(--border);border-radius:4px">
          <span style="font-size:0.8em;color:var(--text-dim);text-transform:uppercase;letter-spacing:0.06em">Урон сверх шкал</span>
          <input type="number" name="system.overflow_damage" value="{{system.overflow_damage}}"
                 class="kk9-input" min="0" style="width:60px;text-align:center"
                 title="Накопленный урон сверх обеих шкал (от заклинаний)" />
          <span style="font-size:0.75em;color:var(--text-dim)">пипов</span>
        </div>

      </div>
      {{/if}}
    </div>
  </div>
</form>
