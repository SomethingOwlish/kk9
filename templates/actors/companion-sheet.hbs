{{!-- КК9 | Карточка спутника v2.0 --}}
<form class="kk9-sheet actor-sheet companion-sheet" autocomplete="off">

  {{!-- ═══ ШАПКА ═══ --}}
  <header class="cp-header">
    <img class="cp-avatar" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" />
    <div class="cp-header-right">
      <div class="cp-name-row">
        <input class="cp-name-input" type="text" name="name"
               value="{{actor.name}}" placeholder="Имя спутника" />
      </div>
      <div class="cp-sub-row">
        {{#if system.species}}<span class="cp-sub-tag">{{system.species}}</span>{{/if}}
        {{#if system.age}}<span class="cp-sub-dim">{{system.age}} лет</span>{{/if}}
        <span class="cp-bond-tag">
          {{#if (eq system.bond 1)}}♡ Знакомый
          {{else if (eq system.bond 2)}}♡♡ Приятель
          {{else if (eq system.bond 3)}}♥ Друг
          {{else if (eq system.bond 4)}}♥♥ Близкий
          {{else}}♥♥♥ Неразлучны{{/if}}
        </span>
      </div>
    </div>
  </header>

  {{!-- Стан --}}
  {{#if isStunned}}
  <div style="display:flex;align-items:center;gap:8px;padding:4px 10px;background:rgba(239,68,68,0.1);border-bottom:1px solid rgba(239,68,68,0.3);font-size:0.78em;color:#f87171;font-family:'Jost',sans-serif">
    <span style="flex:1">⚡ Спутник в стане</span>
    {{#if isGM}}
    <button type="button" class="companion-remove-stun" style="font-size:0.75em;padding:1px 6px;background:rgba(239,68,68,0.15);border:1px solid rgba(239,68,68,0.35);color:#f87171;border-radius:2px;cursor:pointer;white-space:nowrap;width:auto;flex-shrink:0">✕ стан</button>
    {{/if}}
  </div>
  {{/if}}

  {{!-- ═══ ТЕЛО ═══ --}}
  <div class="cp-body">

    {{!-- Основные параметры --}}
    <div class="cp-params-grid">
      <div class="cp-param-block">
        <span class="cp-param-label">Вид</span>
        <input type="text" name="system.species" value="{{system.species}}"
               class="kk9-input" placeholder="Кот, ворон, лисица..." />
      </div>
      <div class="cp-param-block">
        <span class="cp-param-label">Хозяин</span>
        <input type="text" name="system.owner" value="{{system.owner}}"
               class="kk9-input" placeholder="Имя хозяина..." />
      </div>
      <div class="cp-param-block cp-param-block--sm">
        <span class="cp-param-label">Возраст</span>
        <input type="number" name="system.age" value="{{system.age}}"
               class="kk9-input" min="0" />
      </div>
      <div class="cp-param-block">
        <span class="cp-param-label">Привязанность (1–5)</span>
        <div class="cp-bond-row">
          {{#times 5}}
          <div class="cp-bond-pip {{#if (gte ../system.bond this)}}cp-bond-on{{/if}}"
               data-value="{{this}}">♥</div>
          {{/times}}
          <input type="hidden" name="system.bond" value="{{system.bond}}" class="cp-bond-hidden" />
        </div>
      </div>
    </div>

    {{!-- Атрибуты --}}
    <div class="cp-section">
      <div class="cp-section-title">Характеристики</div>
      <div class="npc-attributes-grid">
        {{#each system.attributes as |attr key|}}
        <div class="npc-attr-box cp-attr-roll" data-attr="{{key}}" title="Бросить">
          <span class="npc-attr-label">
            {{#if (eq key "agility")}}Ловкость
            {{else if (eq key "smarts")}}Смекалка
            {{else if (eq key "spirit")}}Дух
            {{else if (eq key "strength")}}Сила
            {{else if (eq key "magic")}}Магия
            {{else}}{{key}}{{/if}}
          </span>
          <span class="npc-attr-die">d{{attr.die}}{{#if attr.modifier}}{{#if (gt attr.modifier 0)}}+{{attr.modifier}}{{else}}{{attr.modifier}}{{/if}}{{/if}}</span>
          <select name="system.attributes.{{key}}.die" class="npc-die-select" onclick="event.stopPropagation()">
            <option value="4"  {{#if (eq attr.die 4)}}selected{{/if}}>d4</option>
            <option value="6"  {{#if (eq attr.die 6)}}selected{{/if}}>d6</option>
            <option value="8"  {{#if (eq attr.die 8)}}selected{{/if}}>d8</option>
            <option value="10" {{#if (eq attr.die 10)}}selected{{/if}}>d10</option>
            <option value="12" {{#if (eq attr.die 12)}}selected{{/if}}>d12</option>
          </select>
          <input type="number" name="system.attributes.{{key}}.modifier"
                 value="{{attr.modifier}}" placeholder="±0" onclick="event.stopPropagation()"
                 class="npc-die-select" style="text-align:center" />
        </div>
        {{/each}}
      </div>
      {{!-- Инициатива из Ловкости + Смекалки --}}
      <div class="derived-bar" style="margin-top:8px;padding:4px 0;background:transparent;border:none">
        <div class="derived-btn companion-roll-initiative" title="Инициатива (Лов + Смек)">
          <span class="derived-lbl">Инициатива</span>
          </div>
      </div>
    </div>

    {{!-- Характер --}}
    <div class="cp-param-block">
      <span class="cp-param-label">Характер</span>
      <textarea name="system.character" class="kk9-textarea cp-char-ta"
                placeholder="Как ведёт себя, что любит, как реагирует...">{{system.character}}</textarea>
    </div>

    {{!-- Описание --}}
    <div class="cp-param-block">
      <span class="cp-param-label">Описание</span>
      <textarea name="system.description" class="kk9-textarea cp-desc-ta"
                placeholder="Внешность, история...">{{system.description}}</textarea>
    </div>

    {{!-- Статусы спутника --}}
    <div class="cp-section">
      <div class="cp-section-title">Активные статусы</div>
      <div class="cp-status-drop-zone companion-status-drop" title="Перетащи статус-итем сюда">
        {{#if activeStatuses.length}}
        <div class="cp-status-list">
          {{#each activeStatuses as |st|}}
          <div class="actor-status-row cp-status-row" data-item-id="{{st.id}}">
            <div class="cp-status-info">
              <span class="cp-status-name item-name-click" style="cursor:pointer">{{st.name}}</span>
              <span class="cp-status-meta">
                {{#if (eq st.duration_mode "counter")}}{{st.duration_value}} раунд.
                {{else if (eq st.duration_mode "charges")}}{{st.duration_value}} зар.
                {{else}}время{{/if}}
              </span>
              {{#if st.status_types.length}}
              <span class="cp-status-tags">
                {{#each st.status_types as |t|}}<span class="cp-status-tag">{{statusTypeLabel t}}</span>{{/each}}
              </span>
              {{/if}}
            </div>
            {{#if ../isGM}}
            <button type="button" class="actor-remove-status fac-del" data-item-id="{{st.id}}">✕</button>
            {{#if (eq st.duration_mode "time")}}
            <button type="button" class="actor-apply-status actor-status-apply-btn"
                    data-item-id="{{st.id}}" title="Применить эффект">▶</button>
            {{/if}}
            {{/if}}
          </div>
          {{/each}}
        </div>
        {{else}}
        <div class="cp-status-empty">Нет статусов · перетащи статус-итем</div>
        {{/if}}
      </div>
    </div>

  </div>

</form>

<style>
.companion-sheet {
  flex-direction: column !important;
  overflow-y: auto;
}

/* ── Шапка ── */
.companion-sheet .cp-header {
  display: flex; flex-direction: row; align-items: center; gap: 12px;
  padding: 10px 14px; background: var(--bg2);
  border-bottom: 1px solid var(--border); flex-shrink: 0;
}
.companion-sheet .cp-avatar {
  width: 48px; height: 48px; border-radius: 50%; object-fit: cover;
  cursor: pointer; flex-shrink: 0; border: 2px solid var(--border2);
}
.companion-sheet .cp-header-right { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 4px; }
.companion-sheet .cp-name-row { display: flex; align-items: center; gap: 8px; }
.companion-sheet .cp-name-input {
  flex: 1; font-family: 'Caveat', cursive; font-size: 1.4em; font-weight: 700;
  background: transparent; border: none;
  border-bottom: 2px solid var(--border2);
  color: var(--text-head); padding: 0 0 1px; outline: none; min-width: 0;
}
.companion-sheet .cp-name-input:focus { border-bottom-color: var(--gold); }
.companion-sheet .cp-sub-row { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
.companion-sheet .cp-sub-tag  { font-size: 0.78em; color: var(--text); }
.companion-sheet .cp-sub-dim  { font-size: 0.72em; color: var(--text-dim); }
.companion-sheet .cp-bond-tag { font-size: 0.72em; color: #f9a8d4; }

/* ── Тело ── */
.companion-sheet .cp-body {
  flex: 1; padding: 12px 14px;
  display: flex; flex-direction: column; gap: 12px; overflow-y: auto;
}
.companion-sheet .cp-params-grid {
  display: grid; grid-template-columns: 1fr auto 1fr; gap: 10px; align-items: end;
}
.companion-sheet .cp-param-block { display: flex; flex-direction: column; gap: 3px; }
.companion-sheet .cp-param-block--sm { min-width: 70px; }
.companion-sheet .cp-param-block--formula { justify-content: flex-end; }
.companion-sheet .cp-param-label {
  font-size: 0.65em; text-transform: uppercase; letter-spacing: 0.07em; color: var(--text-dim);
}

/* Привязанность — пипы сердечки */
.companion-sheet .cp-bond-row { display: flex; align-items: center; gap: 4px; }
.companion-sheet .cp-bond-pip {
  font-size: 1.1em; cursor: pointer; color: var(--border2);
  transition: color 0.15s, transform 0.1s;
}
.companion-sheet .cp-bond-pip:hover { transform: scale(1.2); color: #f9a8d4; }
.companion-sheet .cp-bond-on { color: #ec4899; text-shadow: 0 0 6px rgba(236,72,153,0.4); }

/* Инициатива */
.companion-sheet .cp-section {
  border: 1px solid var(--border); border-radius: 4px;
  padding: 10px 12px; background: var(--bg2);
  display: flex; flex-direction: column; gap: 8px;
}
.companion-sheet .cp-section-title {
  font-size: 0.72em; text-transform: uppercase; letter-spacing: 0.08em;
  color: var(--gold-dim); font-weight: 500;
}
.companion-sheet .cp-init-row {
  display: flex; align-items: flex-end; gap: 10px; flex-wrap: wrap;
}
.companion-sheet .cp-formula {
  font-family: 'Caveat', cursive; font-size: 1.1em;
  color: var(--gold); padding-top: 4px;
}
.companion-sheet .cp-roll-init-btn {
  padding: 4px 12px; align-self: flex-end;
  background: rgba(196,164,74,0.1); border: 1px solid rgba(196,164,74,0.3);
  border-radius: 4px; color: var(--gold); font-family: 'Jost', sans-serif;
  font-size: 0.82em; cursor: pointer; transition: all 0.15s; white-space: nowrap;
}
.companion-sheet .cp-roll-init-btn:hover { background: rgba(196,164,74,0.2); }

.companion-sheet .cp-char-ta { min-height: 90px; }
.companion-sheet .cp-desc-ta { min-height: 70px; }

/* ── Статусы ── */
.companion-sheet .cp-status-drop-zone {
  min-height: 28px; border: 1px dashed var(--border2); border-radius: 3px;
  padding: 4px 6px; background: var(--bg);
}
.companion-sheet .cp-status-drop-zone.cp-drop-hover {
  border-color: var(--gold); background: rgba(196,164,74,0.05);
}
.companion-sheet .cp-status-list { display: flex; flex-direction: column; gap: 4px; }
.companion-sheet .cp-status-row {
  display: flex; align-items: center; justify-content: space-between;
  gap: 6px; padding: 2px 4px;
}
.companion-sheet .cp-status-info { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; flex: 1; }
.companion-sheet .cp-status-name { font-size: 0.82em; color: var(--text); }
.companion-sheet .cp-status-meta { font-size: 0.7em; color: var(--text-dim); }
.companion-sheet .cp-status-tags { display: flex; gap: 3px; flex-wrap: wrap; }
.companion-sheet .cp-status-tag {
  font-size: 0.62em; padding: 1px 5px; border-radius: 8px;
  background: rgba(196,164,74,0.1); color: var(--gold);
  border: 1px solid rgba(196,164,74,0.2);
}
.companion-sheet .cp-status-empty {
  font-size: 0.72em; color: var(--text-dim); font-style: italic;
}
</style>
