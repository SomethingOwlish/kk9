{{!-- Снаряжение --}}
<section class="items-section">

  {{!-- Оружие --}}
  <div class="item-group">
    <div class="item-group-header">
      <span class="item-group-title">Оружие</span>
      <button type="button" class="item-create btn-add-sm" data-type="weapon">+</button>
    </div>
    {{#each weapons}}
    <div class="item-row" data-item-id="{{this.id}}">
      <img src="{{this.img}}" class="item-img" />
      <span class="item-name item-name-click">{{this.name}}</span>
      <span class="item-meta">{{this.system.damage}} · {{this.system.range}}</span>
      <button type="button" class="item-delete btn-delete-xs">✕</button>
    </div>
    {{else}}<p class="empty-hint">Нет оружия</p>{{/each}}
  </div>

  {{!-- Снаряжение --}}
  <div class="item-group">
    <div class="item-group-header">
      <span class="item-group-title">Снаряжение</span>
      <button type="button" class="item-create btn-add-sm" data-type="gear">+</button>
    </div>
    {{#each gear}}
    <div class="item-row" data-item-id="{{this.id}}">
      <img src="{{this.img}}" class="item-img" />
      <span class="item-name item-name-click">{{this.name}}</span>
      {{#if (gt this.system.quantity 1)}}<span class="item-meta">×{{this.system.quantity}}</span>{{/if}}
      <button type="button" class="item-delete btn-delete-xs">✕</button>
    </div>
    {{else}}<p class="empty-hint">Нет снаряжения</p>{{/each}}
  </div>

  {{!-- Артефакты --}}
  <div class="item-group">
    <div class="item-group-header">
      <span class="item-group-title">Артефакты</span>
      <button type="button" class="item-create btn-add-sm" data-type="artifact">+</button>
    </div>
    {{#each artifacts}}
    <div class="item-row artifact-item-row" data-uuid="{{this.uuid}}" data-ref-type="artifact"
         title="Тип: {{this.system.artifact_type}} | Редкость: {{this.system.rarity}} | Состояние: {{this.system.condition}}">
      <img src="{{this.img}}" class="item-img" />
      <span class="item-name item-name-click">{{this.name}}</span>
      {{#if (eq this.system.artifact_type "attack")}}{{#if (eq this.system.equipped "equipped")}}{{#if this.system.active}}
      <button type="button" class="artifact-use-btn btn-ref-action" data-uuid="{{this.uuid}}" data-action="attack" title="Бросок атаки"><i class="fa-solid fa-crosshairs"></i></button>
      {{/if}}{{/if}}{{/if}}
      {{#if (eq this.system.artifact_type "utility")}}{{#if (eq this.system.equipped "equipped")}}{{#if this.system.active}}
      <button type="button" class="artifact-use-btn btn-ref-action" data-uuid="{{this.uuid}}" data-action="energy" title="Восстановить энергию"><i class="fa-solid fa-circle-plus"></i></button>
      {{/if}}{{/if}}{{/if}}
      <button type="button" class="artifact-toggle-btn btn-ref-icon" data-uuid="{{this.uuid}}" data-toggle="active" title="{{#if this.system.active}}Активен{{else}}Неактивен{{/if}}"><i class="fa-solid {{#if this.system.active}}fa-bolt{{else}}fa-bolt-slash{{/if}}"></i></button>
      <button type="button" class="artifact-toggle-btn btn-ref-icon" data-uuid="{{this.uuid}}" data-toggle="equipped" title="{{#if (eq this.system.equipped 'equipped')}}Экипирован{{else if (eq this.system.equipped 'carried')}}С собой{{else}}Дома{{/if}}"><i class="fa-solid {{#if (eq this.system.equipped 'equipped')}}fa-shield{{else if (eq this.system.equipped 'carried')}}fa-bag-shopping{{else}}fa-house{{/if}}"></i></button>
      <button type="button" class="item-delete btn-delete-xs" data-uuid="{{this.uuid}}" data-ref-type="artifact">✕</button>
    </div>
    {{else}}<p class="empty-hint">Нет артефактов</p>{{/each}}
  </div>

  {{!-- Заклинания --}}
  <div class="item-group">
    <div class="item-group-header">
      <span class="item-group-title">Заклинания</span>
      <button type="button" class="item-create btn-add-sm" data-type="spell">+</button>
    </div>
    {{#each spells}}
    <div class="item-row" data-item-id="{{this.id}}">
      <img src="{{this.img}}" class="item-img" />
      <span class="item-name item-name-click">{{this.name}}</span>
      <span class="item-meta">{{this.system.cost}} энергии</span>
      <button type="button" class="item-delete btn-delete-xs">✕</button>
    </div>
    {{else}}<p class="empty-hint">Нет заклинаний</p>{{/each}}
  </div>

  {{!-- Даймоны --}}
  <div class="item-group">
    <div class="item-group-header">
      <span class="item-group-title">Даймоны</span>
      <button type="button" class="item-create btn-add-sm" data-type="daemon">+</button>
    </div>
    {{#each daemons}}
    <div class="item-row" data-uuid="{{this.uuid}}" data-ref-type="daemon">
      <img src="{{this.img}}" class="item-img" />
      <span class="item-name item-name-click">{{this.name}}</span>
      {{#if this.system.summoned}}<span class="item-badge badge-summoned">Призван</span>{{/if}}
      <button type="button" class="item-delete btn-delete-xs" data-uuid="{{this.uuid}}" data-ref-type="daemon">✕</button>
    </div>
    {{else}}<p class="empty-hint">Нет даймонов</p>{{/each}}
  </div>

  {{!-- Тех. устройства --}}
  <div class="item-group">
    <div class="item-group-header">
      <span class="item-group-title">Устройства</span>
      <button type="button" class="item-create btn-add-sm" data-type="device">+</button>
    </div>
    {{#each devices}}
    <div class="item-row" data-item-id="{{this.id}}">
      <img src="{{this.img}}" class="item-img" />
      <span class="item-name item-name-click">{{this.name}}</span>
      <button type="button" class="item-delete btn-delete-xs">✕</button>
    </div>
    {{else}}<p class="empty-hint">Нет устройств</p>{{/each}}
  </div>

  {{!-- Спутники --}}
  <div class="item-group">
    <div class="item-group-header">
      <span class="item-group-title">Спутники</span>
      <button type="button" class="item-create btn-add-sm" data-type="companion">+</button>
    </div>
    {{#each companions}}
    <div class="item-row" data-uuid="{{this.uuid}}" data-ref-type="companion">
      <img src="{{this.img}}" class="item-img" />
      <span class="item-name item-name-click">{{this.name}}</span>
      <button type="button" class="item-delete btn-delete-xs" data-uuid="{{this.uuid}}" data-ref-type="companion">✕</button>
    </div>
    {{else}}<p class="empty-hint">Нет спутников</p>{{/each}}
  </div>

  {{!-- Транспорт --}}
  <div class="item-group">
    <div class="item-group-header">
      <span class="item-group-title">Транспорт</span>
      <button type="button" class="item-create btn-add-sm" data-type="vehicle">+</button>
    </div>
    {{#each vehicles}}
    <div class="item-row" data-item-id="{{this.id}}">
      <img src="{{this.img}}" class="item-img" />
      <span class="item-name item-name-click">{{this.name}}</span>
      <button type="button" class="item-delete btn-delete-xs">✕</button>
    </div>
    {{else}}<p class="empty-hint">Нет транспорта</p>{{/each}}
  </div>


  {{!-- Контакты --}}
  <div class="item-group">
    <div class="item-group-header">
      <span class="item-group-title">Контакты</span>
      <button type="button" class="item-create btn-add-sm" data-type="contact">+</button>
    </div>
    {{#each contacts}}
    <div class="item-row" data-uuid="{{this.uuid}}" data-ref-type="contact">
      <img src="{{this.img}}" class="item-img" />
      <span class="item-name item-name-click">{{this.name}}</span>
      <span class="item-meta">Доступ: {{this.system.access_level}}</span>
      <button type="button" class="item-delete btn-delete-xs" data-uuid="{{this.uuid}}" data-ref-type="contact">✕</button>
    </div>
    {{else}}<p class="empty-hint">Нет контактов. Перетащи или создай.</p>{{/each}}
  </div>

</section>
