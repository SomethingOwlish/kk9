{{!-- Атрибуты + Факультет + Магические таланты v0.6 --}}
<section class="attributes-section">
  <h3 class="section-title">Атрибуты</h3>
  <div class="attributes-grid">
    {{#each system.attributes as |attr key|}}
    <div class="attribute-row">
      <label class="attr-label">{{lookup ../attributeLabels key}}</label>
      <span class="die-badge rollable-attribute" data-attribute="{{key}}" title="Бросить">d{{attr.die}}</span>
      <select name="system.attributes.{{key}}.die" class="die-select">
        <option value="4"  {{#if (eq attr.die 4)}}selected{{/if}}>d4</option>
        <option value="6"  {{#if (eq attr.die 6)}}selected{{/if}}>d6</option>
        <option value="8"  {{#if (eq attr.die 8)}}selected{{/if}}>d8</option>
        <option value="10" {{#if (eq attr.die 10)}}selected{{/if}}>d10</option>
        <option value="12" {{#if (eq attr.die 12)}}selected{{/if}}>d12</option>
        <option value="20" {{#if (eq attr.die 20)}}selected{{/if}}>d20</option>
      </select>
      <span class="wild-die-hint">+d6</span>
      <span class="mod-label">Мод.</span>
      <input type="number" name="system.attributes.{{key}}.modifier" value="{{attr.modifier}}" class="mod-input" />
    </div>
    {{/each}}
  </div>
</section>

{{!-- Факультетские способности на основной вкладке --}}
{{#if facultyItem}}
<section class="faculty-abilities-section" style="--fcolor:{{facultyColor}};border-color:{{facultyColor}}40;background:{{facultyColor}}08;margin-top:12px;padding:8px;border:1px solid;border-radius:4px">
  <h3 class="section-title" style="color:{{facultyColor}};border-color:{{facultyColor}}30">
    <span class="faculty-dot" style="background:{{facultyColor}}"></span>
    {{facultyName}}
  </h3>
  {{#each facultyAbilities as |ab|}}
  <div class="item-row" data-item-id="{{ab.id}}">
    <img src="{{ab.img}}" class="item-img" />
    <span class="item-name item-name-click" style="color:{{../facultyColor}}">{{ab.name}}</span>
    <span class="item-badge cat-{{ab.system.category}}">{{categoryLabel ab.system.category}}</span>
    <button type="button" class="item-delete btn-delete-xs">✕</button>
  </div>
  {{else}}
  <p class="empty-hint">Нет способностей факультета</p>
  {{/each}}
</section>
{{/if}}

{{!-- Магические способности на основной: уровень таланта --}}
{{#if magicAbilities.length}}
<section class="magic-section" style="margin-top:12px;padding:8px;border:1px solid rgba(168,85,247,0.2);border-radius:4px;background:rgba(168,85,247,0.04)">
  <h3 class="section-title magic-title">✦ Магические таланты</h3>
  {{#each magicAbilities as |ab|}}
  <div class="magic-talent-row" data-item-id="{{ab.id}}">
    <span class="magic-talent-name item-name-click">{{ab.name}}</span>
    <select class="magic-level-select" data-item-id="{{ab.id}}">
      <option value="sparks"      {{#if (eq (lookup ../magicLevelMap ab.id) "sparks")}}selected{{/if}}>Зачатки</option>
      <option value="normal"      {{#if (eq (lookup ../magicLevelMap ab.id) "normal")}}selected{{/if}}>Обычный</option>
      <option value="exceptional" {{#if (eq (lookup ../magicLevelMap ab.id) "exceptional")}}selected{{/if}}>Особый талант</option>
    </select>
  </div>
  {{/each}}
</section>
{{/if}}
