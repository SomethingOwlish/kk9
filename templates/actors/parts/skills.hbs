{{!-- Навыки v0.6.2 --}}
<section class="skills-section">

  {{!-- Факультетские навыки --}}
  {{#if facultyAbilities.length}}
  <div class="faculty-skills-block" style="border-color:{{facultyColor}}40;background:{{facultyColor}}08;padding:8px;border:1px solid;border-radius:4px;margin-bottom:10px">
    <h3 class="section-title" style="color:{{facultyColor}};border-color:{{facultyColor}}30">
      <span class="faculty-dot" style="background:{{facultyColor}}"></span>
      Навыки {{facultyName}}
    </h3>
    {{#each facultyAbilities as |ab|}}
    <div class="skill-row" data-item-id="{{ab.id}}">
      <span class="skill-name rollable-ability" data-item-id="{{ab.id}}" style="color:{{../facultyColor}}">{{ab.name}}</span>
      <div class="skill-controls">
        <select class="die-select-sm ability-die-select" data-item-id="{{ab.id}}">
          <option value="4"  {{#if (eq ab.system.die 4)}}selected{{/if}}>d4</option>
          <option value="6"  {{#if (eq ab.system.die 6)}}selected{{/if}}>d6</option>
          <option value="8"  {{#if (eq ab.system.die 8)}}selected{{/if}}>d8</option>
          <option value="10" {{#if (eq ab.system.die 10)}}selected{{/if}}>d10</option>
          <option value="12" {{#if (eq ab.system.die 12)}}selected{{/if}}>d12</option>
          <option value="20" {{#if (eq ab.system.die 20)}}selected{{/if}}>d20</option>
        </select>
        <input type="number" class="mod-input-sm ability-mod-input" data-item-id="{{ab.id}}"
               value="{{ab.system.modifier}}" placeholder="±0" />
        {{!-- Факультетские навыки нельзя удалить вручную --}}
      </div>
    </div>
    {{/each}}
  </div>
  {{/if}}

  {{!-- Основные навыки --}}
  <h3 class="section-title">Основные навыки</h3>
  <div class="skills-list" data-drop-zone="skills-base">
    {{#each baseSkills as |sk|}}
    <div class="skill-row" data-item-id="{{sk.id}}">
      <span class="skill-name rollable-skill" data-item-id="{{sk.id}}">{{sk.name}}</span>
      {{#if sk.system.linkedAttribute}}
      <span class="skill-attr-hint">{{lookup ../attrLabels sk.system.linkedAttribute}}</span>
      {{/if}}
      <div class="skill-controls">
        <select class="die-select-sm skill-die-select" data-item-id="{{sk.id}}"
                data-max-die="{{lookup ../attrDice sk.system.linkedAttribute}}">
          <option value="4"  {{#if (eq sk.system.die 4)}}selected{{/if}}>d4</option>
          <option value="6"  {{#if (eq sk.system.die 6)}}selected{{/if}}>d6</option>
          <option value="8"  {{#if (eq sk.system.die 8)}}selected{{/if}}>d8</option>
          <option value="10" {{#if (eq sk.system.die 10)}}selected{{/if}}>d10</option>
          <option value="12" {{#if (eq sk.system.die 12)}}selected{{/if}}>d12</option>
          <option value="20" {{#if (eq sk.system.die 20)}}selected{{/if}}>d20</option>
        </select>
        <input type="number" class="mod-input-sm skill-mod-input" data-item-id="{{sk.id}}"
               value="{{sk.system.modifier}}" placeholder="±0" />
        {{!-- Кнопка удаления: только learned и personal, никогда common или базовые --}}
        {{#if sk.system.category}}
          {{#unless (eq sk.system.category "common")}}
          <button type="button" class="item-delete btn-delete-skill" data-item-id="{{sk.id}}">✕</button>
          {{/unless}}
        {{/if}}
      </div>
    </div>
    {{else}}
    <p class="empty-hint">Перетащи навыки из компендиума</p>
    {{/each}}
  </div>

  {{!-- Магические способности --}}
  <h3 class="section-title magic-title" style="margin-top:12px">Магические</h3>
  <div class="skills-list" data-drop-zone="abilities-magic">
    {{#each magicAbilities as |ab|}}
    <div class="skill-row" data-item-id="{{ab.id}}">
      <span class="skill-name rollable-ability" data-item-id="{{ab.id}}" style="color:#a855f7">{{ab.name}}</span>
      <div class="skill-controls">
        <select class="die-select-sm ability-die-select" data-item-id="{{ab.id}}">
          <option value="4"  {{#if (eq ab.system.die 4)}}selected{{/if}}>d4</option>
          <option value="6"  {{#if (eq ab.system.die 6)}}selected{{/if}}>d6</option>
          <option value="8"  {{#if (eq ab.system.die 8)}}selected{{/if}}>d8</option>
          <option value="10" {{#if (eq ab.system.die 10)}}selected{{/if}}>d10</option>
          <option value="12" {{#if (eq ab.system.die 12)}}selected{{/if}}>d12</option>
          <option value="20" {{#if (eq ab.system.die 20)}}selected{{/if}}>d20</option>
        </select>
        <input type="number" class="mod-input-sm ability-mod-input" data-item-id="{{ab.id}}" value="{{ab.system.modifier}}" />
        <button type="button" class="item-delete btn-delete-xs" data-item-id="{{ab.id}}">✕</button>
      </div>
    </div>
    {{else}}
    <p class="empty-hint">Перетащи магическую способность из компендиума</p>
    {{/each}}
  </div>

  {{!-- Индивидуальные навыки (способности) --}}
  <div style="display:flex;align-items:center;justify-content:space-between;margin-top:12px;padding-bottom:4px;border-bottom:1px solid var(--border)">
    <span class="section-title" style="margin:0;border:none">Индивидуальные навыки</span>
    <button type="button" class="item-create btn-add-sm" data-type="ability" data-category="personal">+</button>
  </div>
  <div class="skills-list" data-drop-zone="abilities-personal">
    {{#each personalAbilities as |ab|}}
    <div class="skill-row" data-item-id="{{ab.id}}">
      <span class="skill-name rollable-ability" data-item-id="{{ab.id}}">{{ab.name}}</span>
      <div class="skill-controls">
        <select class="die-select-sm ability-die-select" data-item-id="{{ab.id}}">
          <option value="4"  {{#if (eq ab.system.die 4)}}selected{{/if}}>d4</option>
          <option value="6"  {{#if (eq ab.system.die 6)}}selected{{/if}}>d6</option>
          <option value="8"  {{#if (eq ab.system.die 8)}}selected{{/if}}>d8</option>
          <option value="10" {{#if (eq ab.system.die 10)}}selected{{/if}}>d10</option>
          <option value="12" {{#if (eq ab.system.die 12)}}selected{{/if}}>d12</option>
          <option value="20" {{#if (eq ab.system.die 20)}}selected{{/if}}>d20</option>
        </select>
        <input type="number" class="mod-input-sm ability-mod-input" data-item-id="{{ab.id}}" value="{{ab.system.modifier}}" />
        <button type="button" class="item-delete btn-delete-xs" data-item-id="{{ab.id}}">✕</button>
      </div>
    </div>
    {{else}}
    <p class="empty-hint">Нет индивидуальных навыков. Нажми + или перетащи.</p>
    {{/each}}
  </div>



</section>
