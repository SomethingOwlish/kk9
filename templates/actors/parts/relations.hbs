{{!-- Связи с НПС --}}
<section class="relations-section">
  <div class="section-header-row">
    <h3 class="section-title">Связи с НПС</h3>
    <button type="button" class="add-relation btn-add-sm">+</button>
  </div>

  <div class="relations-list" data-drop-zone="relations">
    {{#if system.relations.length}}
    {{#each system.relations as |rel|}}
    <div class="relation-row">
      <input type="text" name="system.relations.{{@index}}.name"
             value="{{rel.name}}" class="relation-name" placeholder="Имя НПС..." />

      <select name="system.relations.{{@index}}.status" class="relation-status">
        <option value="ally"    {{#if (eq rel.status "ally")}}selected{{/if}}>Союзник</option>
        <option value="enemy"   {{#if (eq rel.status "enemy")}}selected{{/if}}>Враг</option>
        <option value="neutral" {{#if (eq rel.status "neutral")}}selected{{/if}}>Нейтрал</option>
        <option value="unknown" {{#if (eq rel.status "unknown")}}selected{{/if}}>Неизвестно</option>
      </select>

      <div class="relation-level-wrap">
        <input type="range" name="system.relations.{{@index}}.level"
               value="{{rel.level}}" min="-15" max="15" class="relation-level-range" />
        <span class="relation-level-val">{{rel.level}}</span>
      </div>

      <textarea name="system.relations.{{@index}}.notes"
                class="relation-notes" placeholder="Заметки...">{{rel.notes}}</textarea>

      <button type="button" class="delete-relation btn-delete-xs" data-index="{{@index}}">✕</button>
    </div>
    {{/each}}
    {{else}}
    <p class="empty-hint">Нет связей. Нажми «+» или перетащи карточку НПС.</p>
    {{/if}}
  </div>
</section>
