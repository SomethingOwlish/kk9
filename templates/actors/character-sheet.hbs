{{!-- КК9 | Карточка персонажа v0.4 --}}
<style>
.chargen-overlay {
  position: absolute; inset: 0; z-index: 100;
  background: var(--bg1, #1a1a1a);
  display: flex; align-items: center; justify-content: center;
  border-radius: 4px;
}
.chargen-overlay-inner {
  display: flex; flex-direction: column; align-items: center;
  gap: 14px; padding: 32px 40px; max-width: 320px; text-align: center;
}
.chargen-overlay-title {
  font-family: 'Cinzel Decorative', serif;
  font-size: 1.2em; color: var(--gold, #c4a44a); letter-spacing: 0.06em;
}
.chargen-overlay-hint {
  font-size: 0.84em; color: var(--text-dim, #888); margin: 0;
}
.chargen-overlay-btn {
  width: 200px; padding: 10px 0; border-radius: 4px; cursor: pointer;
  font-family: 'Jost', sans-serif; font-size: 0.9em; letter-spacing: 0.04em;
  border: 1px solid var(--gold, #c4a44a);
  background: rgba(196,164,74,0.15); color: var(--gold, #c4a44a);
  transition: background 0.15s;
}
.chargen-overlay-btn:hover { background: rgba(196,164,74,0.28); }
.chargen-overlay-btn--secondary {
  background: transparent; border-color: var(--border, #3a3a3a);
  color: var(--text-dim, #888); font-size: 0.8em; padding: 7px 0;
}
.chargen-overlay-btn--secondary:hover { background: rgba(255,255,255,0.05); }
</style>
<form class="kk9-sheet character-sheet {{system.faculty}}" autocomplete="off">

  {{!-- ЛЕВАЯ КОЛОНКА --}}
  <div class="sheet-sidebar">
    <div class="portrait-wrap" style="{{#if system.faculty_color}}outline: 3px solid {{system.faculty_color}}; outline-offset: -3px;{{/if}}">
      <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" />
      <div class="portrait-name-overlay">
        <input class="name-input" type="text" name="name" value="{{actor.name}}" placeholder="Имя" />
      </div>
    </div>

    <div class="sidebar-fields">
      <div class="sfield-row">
        <span class="sfield-label">Курс</span>
        <input type="text" name="system.academy_year" value="{{system.academy_year}}" class="sfield-val" />
      </div>
      <div class="sfield-row">
        <span class="sfield-label">Страна</span>
        <input type="text" name="system.birthplace" value="{{system.birthplace}}" class="sfield-val" placeholder="—" />
      </div>

      {{!-- Факультет — только отображение, меняется перетаскиванием --}}
      <div class="sfield-row faculty-row">
        <span class="sfield-label">Факультет</span>
        {{#if system.faculty_name}}
        <span class="faculty-display" style="flex:1;padding:3px 8px;border-radius:3px;font-size:0.86em;color:var(--text-head);{{#if system.faculty_color}}border-left:3px solid {{system.faculty_color}};background:{{system.faculty_color}}18;{{/if}}">
          {{system.faculty_name}}
        </span>
        {{else}}
        <span class="faculty-display" style="flex:1;padding:3px 8px;font-size:0.78em;color:var(--text-dim);font-style:italic">
          Перетащи факультет
        </span>
        {{/if}}
      </div>

      {{!-- Деньги и Опыт --}}
      <div class="sfield-row">
        <span class="sfield-label">Деньги</span>
        <input type="number" name="system.money" value="{{system.money}}" class="sfield-val" min="0" />
      </div>
      <div class="sfield-row">
        <span class="sfield-label">Опыт</span>
        <input type="number" name="system.experience" value="{{system.experience}}" class="sfield-val" min="0" />
      </div>

      {{!-- Жетоны судьбы — пипы по клику, макс 9 --}}
      <div class="bennies-block">
        <span class="sfield-label">Жетоны судьбы</span>
        <div class="bennies-pips">
          {{#times 9}}
          <div class="bennie-pip {{#if (gte ../system.bennies this)}}bennie-on{{else}}bennie-off{{/if}}"
               data-index="{{this}}" title="Жетон {{this}}">◆</div>
          {{/times}}
        </div>
      </div>
    </div>

    {{!-- Производные внизу сайдбара --}}
    <div class="derived-bar">
      <div class="derived-btn roll-initiative" title="Бросить инициативу (Лов+Смек)">
        <span class="derived-lbl">Инициатива</span>

      </div>
      <div class="derived-btn roll-toughness" title="Бросить стойкость (Дух + навык)">
        <span class="derived-lbl">Стойкость</span>

      </div>
      <div class="derived-energy">
        <span class="derived-lbl">Энергия</span>
        <input type="number" name="system.energy.value" value="{{system.energy.value}}" class="energy-cur" min="0" {{#unless isGM}}readonly title="Только ГМ может изменять энергию вручную"{{/unless}} />
        <span class="energy-sep">/</span>
        <span class="energy-max">{{system.energy.max}}</span>
      </div>
    </div>
  </div>

  {{!-- ПРАВАЯ КОЛОНКА --}}
  <div class="sheet-main">

    {{!-- ШКАЛЫ ЗДОРОВЬЯ --}}
    {{> "systems/kk9/templates/actors/parts/health.hbs"}}

    {{!-- ОВЕРЛЕЙ СОЗДАНИЯ ПЕРСОНАЖА --}}
    {{#unless system.character_created}}
    <div class="chargen-overlay">
      <div class="chargen-overlay-inner">
        <div class="chargen-overlay-title">Персонаж не создан</div>
        <p class="chargen-overlay-hint">Нажми кнопку чтобы начать создание персонажа</p>
        <button type="button" class="chargen-start-btn chargen-overlay-btn">
          Создать персонажа
        </button>
        {{#if isGM}}
        <button type="button" class="chargen-skip-btn chargen-overlay-btn chargen-overlay-btn--secondary">
          Открыть карточку (ГМ)
        </button>
        {{/if}}
      </div>
    </div>
    {{/unless}}

    {{!-- ВКЛАДКИ --}}
    <nav class="sheet-tabs" data-group="primary">
      <a class="item" data-tab="main">Основное</a>
      <a class="item" data-tab="skills">Навыки</a>
      <a class="item" data-tab="items">Снаряжение</a>
      <a class="item" data-tab="relations">Связи</a>
      <a class="item" data-tab="biography">Биография</a>
      {{#if isGM}}<a class="item gm-tab" data-tab="gmnotes">Мастер</a>{{/if}}
    </nav>

    <div class="sheet-body">

      {{!-- ОСНОВНОЕ --}}
      <div class="tab" data-group="primary" data-tab="main">
        {{> "systems/kk9/templates/actors/parts/attributes.hbs"}}
      </div>

      {{!-- НАВЫКИ --}}
      <div class="tab" data-group="primary" data-tab="skills">
        {{> "systems/kk9/templates/actors/parts/skills.hbs"}}
      </div>

      {{!-- СНАРЯЖЕНИЕ --}}
      <div class="tab" data-group="primary" data-tab="items">
        {{> "systems/kk9/templates/actors/parts/items.hbs"}}
      </div>

      {{!-- СВЯЗИ --}}
      <div class="tab" data-group="primary" data-tab="relations">
        {{> "systems/kk9/templates/actors/parts/relations.hbs"}}
      </div>

      {{!-- БИОГРАФИЯ --}}
      <div class="tab" data-group="primary" data-tab="biography">
        {{> "systems/kk9/templates/actors/parts/biography.hbs"}}
      </div>

      {{!-- МАСТЕРСКИЕ ЗАМЕТКИ (только GM) --}}
      {{#if isGM}}
      <div class="tab gm-notes-tab" data-group="primary" data-tab="gmnotes">
        <div class="gm-notes-block">
          <div class="section-title">Мастерские заметки</div>
          <div style="display:flex;align-items:center;gap:12px;margin-bottom:10px;padding:8px 10px;background:var(--bg2);border:1px solid var(--border);border-radius:4px">
            <span style="font-size:0.8em;color:var(--text-dim);text-transform:uppercase;letter-spacing:0.06em">Урон сверх шкал</span>
            <input type="number" name="system.overflow_damage" value="{{system.overflow_damage}}"
                   class="kk9-input" min="0" style="width:60px;text-align:center"
                   title="Накопленный урон сверх обеих шкал (от заклинаний)" />
            <span style="font-size:0.75em;color:var(--text-dim)">пипов</span>
          </div>
          <textarea name="system.gm_notes" rows="20" placeholder="Только для мастера...">{{system.gm_notes}}</textarea>
        </div>
      </div>
      {{/if}}

    </div>
  </div>
</form>
