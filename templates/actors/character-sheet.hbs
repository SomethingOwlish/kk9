{{!-- КК9 | Карточка персонажа v0.4 --}}
<form class="kk9-sheet character-sheet {{system.faculty}}" autocomplete="off">

  {{!-- ЛЕВАЯ КОЛОНКА --}}
  <div class="sheet-sidebar">
    <div class="portrait-wrap faculty-border-{{system.faculty}}">
      <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" />
      <div class="portrait-name-overlay">
        <input class="name-input" type="text" name="name" value="{{actor.name}}" placeholder="Имя" />
      </div>
    </div>

    <div class="sidebar-fields">
      <div class="sfield-row">
        <span class="sfield-label">Курс</span>
        <input type="text" name="system.academy_year" value="{{system.academy_year}}" class="sfield-val" />
      </div>
      <div class="sfield-row">
        <span class="sfield-label">Страна</span>
        <input type="text" name="system.birthplace" value="{{system.birthplace}}" class="sfield-val" placeholder="—" />
      </div>

      {{!-- Факультет --}}
      <div class="sfield-row faculty-row">
        <span class="sfield-label">Факультет</span>
        <select name="system.faculty" class="faculty-select faculty-{{system.faculty}}">
          <option value="">— —</option>
          <option value="white"     {{#if (eq system.faculty "white")}}selected{{/if}}>Белый</option>
          <option value="black"     {{#if (eq system.faculty "black")}}selected{{/if}}>Чёрный</option>
          <option value="blue"      {{#if (eq system.faculty "blue")}}selected{{/if}}>Синий</option>
          <option value="green"     {{#if (eq system.faculty "green")}}selected{{/if}}>Зелёный</option>
          <option value="purple"    {{#if (eq system.faculty "purple")}}selected{{/if}}>Фиолетовый</option>
          <option value="red"       {{#if (eq system.faculty "red")}}selected{{/if}}>Красный</option>
          <option value="brown"     {{#if (eq system.faculty "brown")}}selected{{/if}}>Бурый</option>
          <option value="mercury"   {{#if (eq system.faculty "mercury")}}selected{{/if}}>Ртутный</option>
          <option value="invisible" {{#if (eq system.faculty "invisible")}}selected{{/if}}>Незримый</option>
        </select>
      </div>

      {{!-- Деньги и Опыт --}}
      <div class="sfield-row">
        <span class="sfield-label">Деньги</span>
        <input type="number" name="system.money" value="{{system.money}}" class="sfield-val" min="0" />
      </div>
      <div class="sfield-row">
        <span class="sfield-label">Опыт</span>
        <input type="number" name="system.experience" value="{{system.experience}}" class="sfield-val" min="0" />
      </div>

      {{!-- Жетоны судьбы — пипы по клику, макс 9 --}}
      <div class="bennies-block">
        <span class="sfield-label">Жетоны судьбы</span>
        <div class="bennies-pips">
          {{#times 9}}
          <div class="bennie-pip {{#if (gte ../system.bennies this)}}bennie-on{{else}}bennie-off{{/if}}"
               data-index="{{this}}" title="Жетон {{this}}">◆</div>
          {{/times}}
        </div>
      </div>
    </div>

    {{!-- Производные внизу сайдбара --}}
    <div class="derived-bar">
      <div class="derived-btn roll-initiative" title="Бросить инициативу (Лов+Смек)">
        <span class="derived-lbl">Инициатива</span>
        <span class="derived-ico">🎲</span>
      </div>
      <div class="derived-btn roll-toughness" title="Бросить стойкость (Дух + навык)">
        <span class="derived-lbl">Стойкость</span>
        <span class="derived-ico">🎲</span>
      </div>
      <div class="derived-energy">
        <span class="derived-lbl">Энергия</span>
        <input type="number" name="system.energy.value" value="{{system.energy.value}}" class="energy-cur" min="0" />
        <span class="energy-sep">/</span>
        <span class="energy-max">{{system.energy.max}}</span>
      </div>
    </div>
  </div>

  {{!-- ПРАВАЯ КОЛОНКА --}}
  <div class="sheet-main">

    {{!-- ШКАЛЫ ЗДОРОВЬЯ --}}
    {{> "systems/kk9/templates/actors/parts/health.hbs"}}

    {{!-- ВКЛАДКИ --}}
    <nav class="sheet-tabs" data-group="primary">
      <a class="item" data-tab="main">Основное</a>
      <a class="item" data-tab="skills">Навыки</a>
      <a class="item" data-tab="items">Снаряжение</a>
      <a class="item" data-tab="relations">Связи</a>
      <a class="item" data-tab="biography">Биография</a>
      {{#if isGM}}<a class="item gm-tab" data-tab="gmnotes">🔒 Мастер</a>{{/if}}
    </nav>

    <div class="sheet-body">

      {{!-- ОСНОВНОЕ --}}
      <div class="tab" data-group="primary" data-tab="main">
        {{> "systems/kk9/templates/actors/parts/attributes.hbs"}}
      </div>

      {{!-- НАВЫКИ --}}
      <div class="tab" data-group="primary" data-tab="skills">
        {{> "systems/kk9/templates/actors/parts/skills.hbs"}}
      </div>

      {{!-- СНАРЯЖЕНИЕ --}}
      <div class="tab" data-group="primary" data-tab="items">
        {{> "systems/kk9/templates/actors/parts/items.hbs"}}
      </div>

      {{!-- СВЯЗИ --}}
      <div class="tab" data-group="primary" data-tab="relations">
        {{> "systems/kk9/templates/actors/parts/relations.hbs"}}
      </div>

      {{!-- БИОГРАФИЯ --}}
      <div class="tab" data-group="primary" data-tab="biography">
        {{> "systems/kk9/templates/actors/parts/biography.hbs"}}
      </div>

      {{!-- МАСТЕРСКИЕ ЗАМЕТКИ (только GM) --}}
      {{#if isGM}}
      <div class="tab gm-notes-tab" data-group="primary" data-tab="gmnotes">
        <div class="gm-notes-block">
          <div class="section-title">🔒 Мастерские заметки</div>
          <textarea name="system.gm_notes" rows="20" placeholder="Только для мастера...">{{system.gm_notes}}</textarea>
        </div>
      </div>
      {{/if}}

    </div>
  </div>
</form>
