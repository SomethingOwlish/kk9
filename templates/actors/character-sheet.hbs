{{!-- КК9 | Карточка персонажа — тёмный дизайн --}}
<form class="kk9-sheet character-sheet" autocomplete="off">

  {{!-- ЛЕВАЯ КОЛОНКА: портрет + базовая инфа --}}
  <div class="sheet-sidebar">

    <div class="portrait-wrap">
      <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" />
      <div class="portrait-overlay">
        <span class="wild-card-badge">⭐ Wild Card</span>
      </div>
    </div>

    <div class="sidebar-info">
      <input class="name-input" type="text" name="name" value="{{actor.name}}" placeholder="Имя" />

      <div class="sidebar-row">
        <label>Возраст</label>
        <input type="number" name="system.age" value="{{system.age}}" min="0" />
      </div>
      <div class="sidebar-row">
        <label>Курс</label>
        <input type="text" name="system.academy_year" value="{{system.academy_year}}" />
      </div>

      {{!-- ФАКУЛЬТЕТ --}}
      <div class="sidebar-row faculty-row">
        <label>Факультет</label>
        <select name="system.faculty" class="faculty-select faculty-{{system.faculty}}">
          <option value="" {{#if (eq system.faculty "")}}selected{{/if}}>— не выбран —</option>
          <option value="white"     {{#if (eq system.faculty "white")}}selected{{/if}}>Белый</option>
          <option value="black"     {{#if (eq system.faculty "black")}}selected{{/if}}>Чёрный</option>
          <option value="blue"      {{#if (eq system.faculty "blue")}}selected{{/if}}>Синий</option>
          <option value="green"     {{#if (eq system.faculty "green")}}selected{{/if}}>Зелёный</option>
          <option value="purple"    {{#if (eq system.faculty "purple")}}selected{{/if}}>Фиолетовый</option>
          <option value="red"       {{#if (eq system.faculty "red")}}selected{{/if}}>Красный</option>
          <option value="brown"     {{#if (eq system.faculty "brown")}}selected{{/if}}>Бурый</option>
          <option value="mercury"   {{#if (eq system.faculty "mercury")}}selected{{/if}}>Ртутный</option>
          <option value="invisible" {{#if (eq system.faculty "invisible")}}selected{{/if}}>Незримый</option>
        </select>
      </div>

      {{!-- Жетоны судьбы --}}
      <div class="bennies-row">
        <label>Жетоны судьбы</label>
        <div class="bennies-pips">
          {{#times 5}}
          <div class="bennie {{#if (gt this ../system.bennies)}}bennie-empty{{else}}bennie-full{{/if}}">◆</div>
          {{/times}}
          <input type="number" name="system.bennies" value="{{system.bennies}}" min="0" class="bennies-input" />
        </div>
      </div>
    </div>

    {{!-- Производные --}}
    <div class="derived-block">
      <div class="derived-item">
        <span class="derived-label">Скорость</span>
        <input type="number" name="system.pace" value="{{system.pace}}" class="derived-val" />
      </div>
      <div class="derived-item">
        <span class="derived-label">Парир.</span>
        <span class="derived-val derived-static">{{system.parry}}</span>
      </div>
      <div class="derived-item">
        <span class="derived-label">Стойкость</span>
        <span class="derived-val derived-static">{{system.health.physical.toughness}}</span>
      </div>
    </div>

  </div>

  {{!-- ПРАВАЯ КОЛОНКА: основной контент --}}
  <div class="sheet-main">

    {{!-- ШКАЛА ЗДОРОВЬЯ --}}
    <div class="health-block">
      <div class="health-title">
        <span>Физическое состояние</span>
        <span class="health-state-badge state-{{system.health.physical.value}}">
          {{healthLabel system.health.physical.value}}
        </span>
      </div>
      <div class="health-pips">
        {{#times 5}}
        <div class="health-pip {{#if (gt this ../system.health.physical.value)}}pip-empty{{else}}pip-filled pip-lvl-{{this}}{{/if}}"
             data-value="{{add this 1}}"
             title="{{healthLabel (add this 1)}}">
          <span class="pip-label">{{healthLabel (add this 1)}}</span>
        </div>
        {{/times}}
      </div>
    </div>

    {{!-- ВКЛАДКИ --}}
    <nav class="sheet-tabs" data-group="primary">
      <a class="item" data-tab="main">Основное</a>
      <a class="item" data-tab="skills">Навыки</a>
      <a class="item" data-tab="items">Снаряжение</a>
      <a class="item" data-tab="relations">Связи</a>
      <a class="item" data-tab="biography">Биография</a>
    </nav>

    <div class="sheet-body">

      {{!-- ОСНОВНОЕ: атрибуты --}}
      <div class="tab" data-group="primary" data-tab="main">
        {{> "systems/kk9/templates/actors/parts/attributes.hbs"}}
        <div class="notes-block">
          <label class="block-label">Заметки</label>
          <textarea name="system.notes" rows="4" placeholder="Заметки о персонаже...">{{system.notes}}</textarea>
        </div>
      </div>

      {{!-- НАВЫКИ --}}
      <div class="tab" data-group="primary" data-tab="skills">
        {{> "systems/kk9/templates/actors/parts/skills.hbs"}}
      </div>

      {{!-- СНАРЯЖЕНИЕ --}}
      <div class="tab" data-group="primary" data-tab="items">
        {{> "systems/kk9/templates/actors/parts/items.hbs"}}
      </div>

      {{!-- СВЯЗИ --}}
      <div class="tab" data-group="primary" data-tab="relations">
        {{> "systems/kk9/templates/actors/parts/relations.hbs"}}
      </div>

      {{!-- БИОГРАФИЯ --}}
      <div class="tab" data-group="primary" data-tab="biography">
        {{editor system.biography target="system.biography" button=true editable=editable}}
      </div>

    </div>
  </div>

</form>
